<huskui:AppWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:huskui="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:vm="clr-namespace:QuadroApp.ViewModels"
    x:Class="QuadroApp.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Title="{Binding AppVersion, StringFormat='QuadroApp {0}'}"
    Width="1200"
    Height="820"
    MinWidth="1024"
    MinHeight="700">

	<Panel>
		<ContentControl Content="{Binding CurrentViewModel}" />

		<!-- Growl-style toast overlay – top centre -->
		<ItemsControl ItemsSource="{Binding Toast.Messages}"
					  HorizontalAlignment="Center"
					  VerticalAlignment="Top"
					  Margin="0,24,0,0">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Spacing="6"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<!-- Outer panel for drop shadow clearance -->
					<Panel Margin="3">
						<Border CornerRadius="6"
								Background="White"
								BorderBrush="{Binding AccentBrush}"
								BorderThickness="0,3,0,0"
								MinWidth="260"
								MaxWidth="380"
								ClipToBounds="False">
							<Border.Effect>
								<DropShadowEffect BlurRadius="12"
												  OffsetX="0"
												  OffsetY="2"
												  Opacity="0.15"
												  Color="Black"/>
							</Border.Effect>
							<Border CornerRadius="6" ClipToBounds="True">
								<Grid Margin="12,8" RowDefinitions="Auto,Auto,Auto">
									<!-- Title row -->
									<TextBlock Grid.Row="0"
											   Text="{Binding Title}"
											   FontWeight="SemiBold"
											   FontSize="13"
											   Foreground="#1a1a1a"/>
									<!-- Message row -->
									<TextBlock Grid.Row="1"
											   Text="{Binding Message}"
											   FontSize="12"
											   Foreground="#555555"
											   TextWrapping="Wrap"
											   Margin="0,3,0,0"/>
									<!-- Optional action button (e.g. "Herstart nu") -->
									<Button Grid.Row="2"
											Content="{Binding ActionLabel}"
											Command="{Binding ActionCommand}"
											IsVisible="{Binding HasAction}"
											HorizontalAlignment="Right"
											Background="Transparent"
											Foreground="{Binding AccentBrush}"
											FontSize="12"
											FontWeight="SemiBold"
											Padding="0,6,0,2"
											Cursor="Hand"/>
								</Grid>
							</Border>
						</Border>
					</Panel>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- US-32: login / lock overlay -->
		<Border IsVisible="{Binding IsLocked}"
				Background="#E6444A50">
			<Border Background="White"
					CornerRadius="10"
					Padding="32"
					Width="360"
					HorizontalAlignment="Center"
					VerticalAlignment="Center">
				<StackPanel Spacing="12">
					<TextBlock Text="QuadroApp"
							   FontSize="22" FontWeight="Bold"
							   HorizontalAlignment="Center"
							   Foreground="#444A50"/>
					<TextBlock Text="Meld je aan om verder te gaan"
							   FontSize="13" Opacity="0.7"
							   HorizontalAlignment="Center"/>
					<TextBox Watermark="Gebruikersnaam"
							 Text="{Binding LoginGebruikersnaam}"/>
					<TextBox Watermark="Wachtwoord"
							 PasswordChar="●"
							 Text="{Binding LoginWachtwoord}">
						<TextBox.KeyBindings>
							<KeyBinding Gesture="Enter" Command="{Binding LoginCommand}"/>
						</TextBox.KeyBindings>
					</TextBox>
					<TextBlock Text="{Binding LoginFout}"
							   Foreground="#C0392B"
							   FontSize="12"
							   TextWrapping="Wrap"
							   IsVisible="{Binding LoginFout, Converter={x:Static ObjectConverters.IsNotNull}}"/>
					<Button Content="Aanmelden"
							Command="{Binding LoginCommand}"
							HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Center"
							Background="#F5C242"
							Foreground="#444A50"
							FontWeight="SemiBold"
							Padding="0,10"/>
				</StackPanel>
			</Border>
		</Border>

		<!-- Version badge – bottom-right, subtle -->
		<TextBlock Text="{Binding AppVersion, StringFormat='QuadroApp2 {0}'}"
				   HorizontalAlignment="Right"
				   VerticalAlignment="Bottom"
				   Margin="0,0,10,6"
				   FontSize="11"
				   Opacity="0.35"
				   Foreground="#555555"
				   IsHitTestVisible="False"/>
	</Panel>

</huskui:AppWindow>