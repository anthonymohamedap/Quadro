<!-- Styles/QuadroTheme.axaml -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:huskui="https://github.com/d3ara1n/Huskui.Avalonia">

	<!-- Global resources (colors, thickness, corner radius, etc.) -->
	<Styles.Resources>
		<!-- ============================================================= -->
		<!-- DESIGN TOKENS (fase 0 — single source of truth)               -->
		<!-- Views gebruiken uitsluitend {DynamicResource ...}; geen hex.  -->
		<!-- ============================================================= -->

		<!-- Brand -->
		<Color x:Key="BrandYellowColor">#F5C242</Color>
		<Color x:Key="BrandYellowHoverColor">#FFECB3</Color>
		<Color x:Key="BrandDarkColor">#444A50</Color>
		<SolidColorBrush x:Key="BrandYellow" Color="{StaticResource BrandYellowColor}"/>
		<SolidColorBrush x:Key="BrandYellowHover" Color="{StaticResource BrandYellowHoverColor}"/>
		<SolidColorBrush x:Key="BrandDark" Color="{StaticResource BrandDarkColor}"/>

		<!-- Tekst -->
		<Color x:Key="TextPrimaryColor">#222222</Color>
		<Color x:Key="TextSecondaryColor">#6B7280</Color>
		<Color x:Key="TextHeadingColor">#111827</Color>
		<Color x:Key="TextOnDarkColor">#FFFFFF</Color>
		<SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
		<SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
		<SolidColorBrush x:Key="TextHeading" Color="{StaticResource TextHeadingColor}"/>
		<SolidColorBrush x:Key="TextOnDark" Color="{StaticResource TextOnDarkColor}"/>

		<!-- Randen & vlakken -->
		<Color x:Key="BorderSubtleColor">#E5E7EB</Color>
		<Color x:Key="SurfaceColor">#FFFFFF</Color>
		<Color x:Key="SurfaceMutedColor">#F5F5F5</Color>
		<Color x:Key="SurfaceMutedAltColor">#F9FAFB</Color>
		<Color x:Key="SurfaceHeaderColor">#F3F4F6</Color>
		<SolidColorBrush x:Key="BorderSubtle" Color="{StaticResource BorderSubtleColor}"/>
		<SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}"/>
		<SolidColorBrush x:Key="SurfaceMuted" Color="{StaticResource SurfaceMutedColor}"/>
		<SolidColorBrush x:Key="SurfaceMutedAlt" Color="{StaticResource SurfaceMutedAltColor}"/>
		<SolidColorBrush x:Key="SurfaceHeader" Color="{StaticResource SurfaceHeaderColor}"/>

		<!-- Info -->
		<Color x:Key="InfoBgColor">#F0F6FF</Color>
		<Color x:Key="InfoBorderColor">#BFDBFE</Color>
		<Color x:Key="InfoTextColor">#1E40AF</Color>
		<SolidColorBrush x:Key="InfoBg" Color="{StaticResource InfoBgColor}"/>
		<SolidColorBrush x:Key="InfoBorder" Color="{StaticResource InfoBorderColor}"/>
		<SolidColorBrush x:Key="InfoText" Color="{StaticResource InfoTextColor}"/>

		<!-- Semantisch -->
		<Color x:Key="DangerColor">#DC2626</Color>
		<Color x:Key="DangerBgColor">#FEE2E2</Color>
		<Color x:Key="SuccessColor">#16A34A</Color>
		<Color x:Key="SuccessBgColor">#ECFDF5</Color>
		<Color x:Key="WarningColor">#B45309</Color>
		<Color x:Key="WarningBgColor">#FEF3C7</Color>
		<SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}"/>
		<SolidColorBrush x:Key="DangerBg" Color="{StaticResource DangerBgColor}"/>
		<Color x:Key="SuccessBorderColor">#A7F3D0</Color>
		<SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}"/>
		<SolidColorBrush x:Key="SuccessBorder" Color="{StaticResource SuccessBorderColor}"/>
		<SolidColorBrush x:Key="SuccessBg" Color="{StaticResource SuccessBgColor}"/>
		<SolidColorBrush x:Key="Warning" Color="{StaticResource WarningColor}"/>
		<SolidColorBrush x:Key="WarningBg" Color="{StaticResource WarningBgColor}"/>

		<!-- Fase 1 — dark sidebar (HomeView) -->
		<Color x:Key="BrandDarkHoverColor">#55606A</Color>
		<Color x:Key="TextMutedOnDarkColor">#9CA3AF</Color>
		<SolidColorBrush x:Key="BrandDarkHover" Color="{StaticResource BrandDarkHoverColor}"/>
		<SolidColorBrush x:Key="TextMutedOnDark" Color="{StaticResource TextMutedOnDarkColor}"/>

		<!-- Fase 1 — stat-tegels (dashboard) -->
		<Color x:Key="StatOrangeBgColor">#FFF7ED</Color>
		<Color x:Key="StatOrangeTextColor">#7C2D12</Color>
		<Color x:Key="StatRedBgColor">#FEF2F2</Color>
		<Color x:Key="StatRedTextColor">#991B1B</Color>
		<Color x:Key="StatBlueBgColor">#EFF6FF</Color>
		<Color x:Key="StatBlueTextColor">#1D4ED8</Color>
		<Color x:Key="StatPurpleBgColor">#FDF4FF</Color>
		<Color x:Key="StatPurpleTextColor">#7E22CE</Color>
		<SolidColorBrush x:Key="StatOrangeBg" Color="{StaticResource StatOrangeBgColor}"/>
		<SolidColorBrush x:Key="StatOrangeText" Color="{StaticResource StatOrangeTextColor}"/>
		<SolidColorBrush x:Key="StatRedBg" Color="{StaticResource StatRedBgColor}"/>
		<SolidColorBrush x:Key="StatRedText" Color="{StaticResource StatRedTextColor}"/>
		<SolidColorBrush x:Key="StatBlueBg" Color="{StaticResource StatBlueBgColor}"/>
		<SolidColorBrush x:Key="StatBlueText" Color="{StaticResource StatBlueTextColor}"/>
		<SolidColorBrush x:Key="StatPurpleBg" Color="{StaticResource StatPurpleBgColor}"/>
		<SolidColorBrush x:Key="StatPurpleText" Color="{StaticResource StatPurpleTextColor}"/>

		<!-- Fase 1 — icoon-accenten (kaartknoppen) -->
		<Color x:Key="IconBlueColor">#3B82F6</Color>
		<Color x:Key="IconBlueBgColor">#EEF4FF</Color>
		<Color x:Key="IconGreenColor">#22C55E</Color>
		<Color x:Key="IconGreenBgColor">#F0FDF4</Color>
		<Color x:Key="IconOrangeColor">#F97316</Color>
		<Color x:Key="IconPurpleColor">#A855F7</Color>
		<Color x:Key="IconEmeraldColor">#10B981</Color>
		<Color x:Key="IconEmeraldBgColor">#ECFDF5</Color>
		<Color x:Key="IconRoseColor">#F43F5E</Color>
		<Color x:Key="IconRoseBgColor">#FFF1F2</Color>
		<Color x:Key="IconSlateColor">#64748B</Color>
		<Color x:Key="IconSlateBgColor">#F8FAFC</Color>
		<SolidColorBrush x:Key="IconBlue" Color="{StaticResource IconBlueColor}"/>
		<SolidColorBrush x:Key="IconBlueBg" Color="{StaticResource IconBlueBgColor}"/>
		<SolidColorBrush x:Key="IconGreen" Color="{StaticResource IconGreenColor}"/>
		<SolidColorBrush x:Key="IconGreenBg" Color="{StaticResource IconGreenBgColor}"/>
		<SolidColorBrush x:Key="IconOrange" Color="{StaticResource IconOrangeColor}"/>
		<SolidColorBrush x:Key="IconOrangeBg" Color="{StaticResource StatOrangeBgColor}"/>
		<SolidColorBrush x:Key="IconPurple" Color="{StaticResource IconPurpleColor}"/>
		<SolidColorBrush x:Key="IconPurpleBg" Color="{StaticResource StatPurpleBgColor}"/>
		<SolidColorBrush x:Key="IconEmerald" Color="{StaticResource IconEmeraldColor}"/>
		<SolidColorBrush x:Key="IconEmeraldBg" Color="{StaticResource IconEmeraldBgColor}"/>
		<SolidColorBrush x:Key="IconRose" Color="{StaticResource IconRoseColor}"/>
		<SolidColorBrush x:Key="IconRoseBg" Color="{StaticResource IconRoseBgColor}"/>
		<SolidColorBrush x:Key="IconSlate" Color="{StaticResource IconSlateColor}"/>
		<SolidColorBrush x:Key="IconSlateBg" Color="{StaticResource IconSlateBgColor}"/>

		<!-- Planning — capaciteitskleuren dagbezetting (kalender), semantisch -->
		<SolidColorBrush x:Key="CapacityLow" Color="{StaticResource SuccessColor}"/>
		<SolidColorBrush x:Key="CapacityMid" Color="{StaticResource BrandYellowColor}"/>
		<SolidColorBrush x:Key="CapacityHigh" Color="{StaticResource IconOrangeColor}"/>
		<SolidColorBrush x:Key="CapacityFull" Color="{StaticResource DangerColor}"/>

		<!-- Fase 4 — schaduwen & overlays (laatste hex-restanten uit views) -->
		<BoxShadows x:Key="ShadowBar">0 1 4 0 #14000000</BoxShadows>
		<BoxShadows x:Key="ShadowCard">0 1 4 0 #18000000</BoxShadows>
		<BoxShadows x:Key="ShadowPanel">-4 0 16 0 #30000000</BoxShadows>
		<BoxShadows x:Key="ShadowTopEdge">0 -1 4 0 #10000000</BoxShadows>
		<Color x:Key="OverlayDimColor">#80000000</Color>
		<Color x:Key="OverlayLightColor">#80FFFFFF</Color>
		<SolidColorBrush x:Key="OverlayDim" Color="{StaticResource OverlayDimColor}"/>
		<SolidColorBrush x:Key="OverlayLight" Color="{StaticResource OverlayLightColor}"/>

		<!-- Spacing-schaal 4/8/12/16/24/32 -->
		<Thickness x:Key="SpaceXs">4</Thickness>
		<Thickness x:Key="SpaceSm">8</Thickness>
		<Thickness x:Key="SpaceMd">12</Thickness>
		<Thickness x:Key="SpaceLg">16</Thickness>
		<Thickness x:Key="SpaceXl">24</Thickness>
		<Thickness x:Key="SpaceXxl">32</Thickness>

		<!-- Bestaande resources (legacy, blijven werken) -->
		<Color x:Key="QuadroAccentColor">#F6C43E</Color>
		<Color x:Key="QuadroHeaderColor">#3A3A3A</Color>
		<Color x:Key="QuadroTextDark">#000000</Color>
		<Color x:Key="QuadroTextLight">#000000 </Color>
		<Color x:Key="QuadroBorder">#E0E0E0</Color>
		<Color x:Key="QuadroBackground">#F8F8F8</Color>

		<!-- Misc -->
		<Thickness x:Key="QuadroPagePadding">20</Thickness>
		<CornerRadius x:Key="QuadroCorner">10</CornerRadius>
	</Styles.Resources>

	<!-- ============================================================= -->
	<!-- TYPOGRAFIE-CLASSES (fase 0) — géén losse FontSize in views    -->
	<!-- ============================================================= -->
	<Style Selector="TextBlock.h1">
		<Setter Property="FontSize" Value="22"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Foreground" Value="{DynamicResource TextHeading}"/>
	</Style>
	<Style Selector="TextBlock.h2">
		<Setter Property="FontSize" Value="17"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Foreground" Value="{DynamicResource TextHeading}"/>
	</Style>
	<Style Selector="TextBlock.h3">
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Foreground" Value="{DynamicResource TextHeading}"/>
	</Style>
	<Style Selector="TextBlock.body">
		<Setter Property="FontSize" Value="13"/>
	</Style>
	<Style Selector="TextBlock.caption">
		<Setter Property="FontSize" Value="11"/>
		<Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
	</Style>
	<Style Selector="TextBlock.label">
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="FontWeight" Value="Medium"/>
	</Style>
	<!-- Icon-glyphs (emoji) — vaste maten toegestaan als icoon -->
	<Style Selector="TextBlock.iconLarge">
		<Setter Property="FontSize" Value="36"/>
	</Style>

	<!-- ============================================================= -->
	<!-- HERBRUIKBARE LAYOUT-STIJLEN (fase 0)                          -->
	<!-- ============================================================= -->

	<!-- Kaart: witte container met subtiele rand -->
	<Style Selector="Border.Card">
		<Setter Property="Background" Value="{DynamicResource Surface}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="Padding" Value="16"/>
	</Style>

	<!-- Formulierrij: label + input, consistente verticale ruimte -->
	<Style Selector="StackPanel.FormRow">
		<Setter Property="Spacing" Value="4"/>
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>
	<Style Selector="Grid.FormRow">
		<Setter Property="Margin" Value="0,0,0,12"/>
	</Style>

	<!-- Paginasectie: blok met ruimte eronder -->
	<Style Selector="StackPanel.PageSection">
		<Setter Property="Margin" Value="0,0,0,24"/>
	</Style>
	<Style Selector="Border.PageSection">
		<Setter Property="Margin" Value="0,0,0,24"/>
	</Style>

	<!-- Tekstbescherming: cellen in DataGrids trimmen standaard -->
	<Style Selector="DataGridCell TextBlock">
		<Setter Property="TextTrimming" Value="CharacterEllipsis"/>
	</Style>

	<!-- Text styles -->
	<Style Selector="TextBlock.quadro-title">
		<Setter Property="FontSize" Value="22"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="Foreground" Value="{DynamicResource QuadroTextDark}"/>
	</Style>

	<Style Selector="TextBlock.quadro-subtitle">
		<Setter Property="FontSize" Value="14"/>
		<Setter Property="Foreground" Value="{DynamicResource QuadroTextLight}"/>
		<Setter Property="FontStyle" Value="Italic"/>
	</Style>

	<!-- Buttons -->
	<Style Selector="Button.quadro-accent">
		<Setter Property="Background" Value="{DynamicResource QuadroAccentColor}"/>
		<Setter Property="Foreground" Value="Black"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Padding" Value="8,4"/>
		<Setter Property="CornerRadius" Value="6"/>
	</Style>

	<Style Selector="Button.quadro-default">
		<Setter Property="Background" Value="#E0E0E0"/>
		<Setter Property="Foreground" Value="#333"/>
		<Setter Property="FontWeight" Value="SemiBold"/>
		<Setter Property="Padding" Value="8,4"/>
		<Setter Property="CornerRadius" Value="6"/>
	</Style>

	<!-- Card border -->
	<Style Selector="Border.quadro-card">
		<Setter Property="Background" Value="White"/>
		<Setter Property="CornerRadius" Value="12"/>
		<Setter Property="BorderBrush" Value="{DynamicResource QuadroBorder}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="Padding" Value="15"/>
	</Style>
	<Style Selector="Button.IconBtn">
		<Setter Property="Width" Value="40"/>
		<Setter Property="Height" Value="40"/>
		<Setter Property="FontSize" Value="18"/>
		<Setter Property="CornerRadius" Value="6"/>
		<Setter Property="Background" Value="#444A50"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="Margin" Value="4"/>
	</Style>

	<Style Selector="Button.IconBtn:pointerover">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="Foreground" Value="#222"/>
	</Style>
	
	<!-- Buttons: MainBtn (globaal) -->
	<Style Selector="Button.MainBtn">
		<Setter Property="Background" Value="#444A50"/>
		<Setter Property="Foreground" Value="White"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="BorderBrush" Value="Transparent"/>
		<Setter Property="FontSize" Value="15"/>
		<Setter Property="Padding" Value="10,5"/>
	</Style>
	<Style Selector="Button.MainBtn:pointerover">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="Foreground" Value="#222"/>
	</Style>

	<!-- Button.AccentBtn: gele brand-actieknop (fase 1) -->
	<Style Selector="Button.AccentBtn">
		<Setter Property="Background" Value="{DynamicResource BrandYellow}"/>
		<Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
		<Setter Property="FontWeight" Value="Bold"/>
		<Setter Property="CornerRadius" Value="6"/>
	</Style>
	<Style Selector="Button.AccentBtn:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource BrandYellowHover}"/>
	</Style>

	<!-- Button.GhostBtn (herbruikbaar, secundaire actie op lichte achtergrond) -->
	<Style Selector="Button.GhostBtn">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="12,6"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="Cursor" Value="Hand"/>
	</Style>
	<Style Selector="Button.GhostBtn:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource SurfaceMuted}"/>
	</Style>

	<!-- Button.DangerBtn (herbruikbaar, destructieve/blokkeer-actie) -->
	<Style Selector="Button.DangerBtn">
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="{DynamicResource Danger}"/>
		<Setter Property="BorderBrush" Value="{DynamicResource Danger}"/>
		<Setter Property="BorderThickness" Value="1"/>
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Padding" Value="12,6"/>
		<Setter Property="FontSize" Value="12"/>
		<Setter Property="Cursor" Value="Hand"/>
	</Style>
	<Style Selector="Button.DangerBtn:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="{DynamicResource DangerBg}"/>
	</Style>

	<!-- TextBlock: standaard zwart voor lichte views -->
	<Style Selector="TextBlock">
		<Setter Property="Foreground" Value="Black"/>
	</Style>

	<!-- ListBoxItem: standaard Quadro-stijl -->
	<Style Selector="ListBoxItem">
		<Setter Property="CornerRadius" Value="8"/>
		<Setter Property="Margin" Value="0,0,0,6"/>
		<Setter Property="Padding" Value="10"/>
		<Setter Property="Background" Value="Transparent"/>
		<Setter Property="Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ListBoxItem /template/ ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ListBoxItem:pointerover">
		<Setter Property="Background" Value="#FFF7DA"/>
	</Style>
	
	<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter  Property="CornerRadius"  Value="8"/>
		<Setter Property="TextElement.Foreground" Value="#222"/>
	</Style>
	<Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
		<Setter Property="Background" Value="#FFECB3"/>
	</Style>

	<!-- CheckBox: custom stijl met vinkje -->
	<Style Selector="CheckBox">
		<Setter Property="Template">
			<ControlTemplate>
				<Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalAlignment="Center">
					<Border x:Name="CheckBorder"
					        Grid.Column="0"
					        Width="18" Height="18"
					        CornerRadius="4"
					        BorderThickness="2"
					        BorderBrush="#CCCCCC"
					        Background="White"
					        VerticalAlignment="Center">
						<Path x:Name="CheckMark"
						      Data="M 3,9 L 7,13 L 15,4"
						      Stroke="White"
						      StrokeThickness="2.2"
						      StrokeLineCap="Round"
						      IsVisible="False"
						      Stretch="None"/>
					</Border>
					<ContentPresenter Grid.Column="1"
					                  Content="{TemplateBinding Content}"
					                  ContentTemplate="{TemplateBinding ContentTemplate}"
					                  VerticalAlignment="Center"
					                  HorizontalAlignment="Left"/>
				</Grid>
			</ControlTemplate>
		</Setter>
	</Style>

	<Style Selector="CheckBox:checked /template/ Border#CheckBorder">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="BorderBrush" Value="#E0A800"/>
	</Style>

	<Style Selector="CheckBox:checked /template/ Path#CheckMark">
		<Setter Property="IsVisible" Value="True"/>
	</Style>

	<Style Selector="CheckBox:pointerover /template/ Border#CheckBorder">
		<Setter Property="BorderBrush" Value="#F5C242"/>
		<Setter Property="Background" Value="#FFFDE7"/>
	</Style>

	<Style Selector="CheckBox:indeterminate /template/ Border#CheckBorder">
		<Setter Property="Background" Value="#F5C242"/>
		<Setter Property="BorderBrush" Value="#E0A800"/>
	</Style>

	<!-- DataGrid: horizontale lijnen, lichte header -->
	<Style Selector="DataGrid">
		<Setter Property="GridLinesVisibility" Value="Horizontal"/>
	</Style>
	<Style Selector="DataGridColumnHeader">
		<Setter Property="Background" Value="#F3F4F6"/>
		<Setter Property="Foreground" Value="#000"/>
		<Setter Property="BorderBrush" Value="#E5E7EB"/>
	</Style>

	<!-- ScrollBar: slim design -->
	<Style Selector="ScrollBar">
		<Setter Property="Width" Value="6"/>
		<Setter Property="Opacity" Value="0.5"/>
	</Style>

	<!-- ComboBox: witte achtergrond, zwarte tekst, licht geel op hover -->
	<Style Selector="ComboBox">
		<Setter Property="Background" Value="White"/>
		<Setter Property="Foreground" Value="#222222"/>
		<Setter Property="BorderBrush" Value="#CCCCCC"/>
	</Style>
	<Style Selector="ComboBox:pointerover">
		<Setter Property="Background" Value="#FFFDE7"/>
	</Style>
	<Style Selector="ComboBox /template/ Border#Background">
		<Setter Property="Background" Value="White"/>
	</Style>

	<!-- Centre the Huskui growl/toast notifications -->
	<Style Selector="huskui|AppWindow /template/ huskui|GrowlHost">
		<Setter Property="HorizontalAlignment" Value="Center"/>
		<Setter Property="VerticalAlignment" Value="Center"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="Margin" Value="0"/>
	</Style>
	<Style Selector="ComboBox /template/ ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem">
		<Setter Property="Background" Value="White"/>
		<Setter Property="Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>
	<Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
		<Setter Property="TextElement.Foreground" Value="#222222"/>
	</Style>


</Styles>
