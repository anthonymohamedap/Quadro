<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:QuadroApp.Converters"
    x:Class="QuadroApp.Views.WerkBonLijstView"
    x:Name="Root"
    x:DataType="vm:WerkBonLijstViewModel"
    d:DataContext="{d:DesignInstance vm:WerkBonLijstViewModel, IsDesignTimeCreatable=True}"
    Background="#F5F5F5">

	<!-- Resources -->
	<UserControl.Resources>
		<conv:JaarConverter x:Key="JaarConv"/>
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*">

		<!-- HEADER -->
		<Border Grid.Row="0" Background="#444A50" Height="70">
			<DockPanel Margin="20,0">

				<StackPanel DockPanel.Dock="Left"
							Orientation="Horizontal"
							VerticalAlignment="Center"
							Spacing="10">
					<Ellipse Width="35" Height="35" Fill="#F5C242"/>
					<TextBlock Text="QUADRO"
							   FontSize="20"
							   FontWeight="Bold"
							   Foreground="Black"/>
					<TextBlock Text="WERKBONNEN"
							   FontSize="13"
							   Foreground="Black"
							   Margin="20,0,0,0"/>
				</StackPanel>

				<Button Content="⬅️ Terug"
						Command="{Binding GaTerugCommand}"
						DockPanel.Dock="Right"
						VerticalAlignment="Top"
						HorizontalAlignment="Right"
						Margin="0,10,10,0"
						Background="#F5C242"
						Foreground="#222"
						FontWeight="Bold"
						CornerRadius="8"
						Padding="10,5"
						Width="100"
						Height="32"/>
			</DockPanel>
		</Border>

		<!-- MAIN -->
		<Grid Grid.Row="1"
			  Margin="20"
			  ColumnDefinitions="*,Auto"
			  ColumnSpacing="20">

			<!-- LINKS -->
			<ScrollViewer Grid.Column="0"
						  VerticalScrollBarVisibility="Auto"
						  HorizontalScrollBarVisibility="Disabled">

				<StackPanel Spacing="14">

					<TextBlock Text="🧾 Werkbonnen"
							   FontSize="22"
							   FontWeight="Bold"/>

					<!-- Search + tools -->
					<Grid ColumnDefinitions="280,Auto" ColumnSpacing="10">

						<StackPanel Grid.Column="0"
									Orientation="Horizontal"
									Spacing="8"
									VerticalAlignment="Center">
							<TextBox Height="34"
									 Width="200"
									 Foreground="#222"
									 Watermark="Zoek op bonnr of klant…"
									 Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
							<ComboBox ItemsSource="{Binding BeschikbareJaren}"
									  SelectedItem="{Binding GeselecteerdJaar, Mode=TwoWay}"
									  Width="110"
									  Height="34"
									  VerticalAlignment="Center">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Converter={StaticResource JaarConv}}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>

						<StackPanel Grid.Column="1"
									Orientation="Horizontal"
									Spacing="6"
									VerticalAlignment="Center">
							<Button Content="🔄 Ververs"
									ToolTip.Tip="Ververs"
									Command="{Binding RefreshCommand}"
									Classes="MainBtn"/>
							<Button Content="📅 Planning openen"
									ToolTip.Tip="Planning openen"
									Command="{Binding OpenPlanningCommand}"
									Classes="MainBtn"/>
						</StackPanel>

					</Grid>

					<!-- Headers -->
					<Grid ColumnDefinitions="0.5*,1.8*,1.2*,1.1*,Auto">
						<TextBlock Text="Bon" Grid.Column="0" FontWeight="Bold" TextAlignment="Center"/>
						<TextBlock Text="Klant" Grid.Column="1" FontWeight="Bold" TextAlignment="Center"/>
						<TextBlock Text="Status" Grid.Column="2" FontWeight="Bold" TextAlignment="Center"/>
						<TextBlock Text="Aangemaakt" Grid.Column="3" FontWeight="Bold" TextAlignment="Center"/>
						<TextBlock Text="" Grid.Column="4" Width="90"/>
					</Grid>

					<Border Background="White"
							BorderBrush="#DDD"
							BorderThickness="1"
							CornerRadius="8"
							Padding="4">

						<ListBox ItemsSource="{Binding WerkBonnen}"
								 SelectedItem="{Binding SelectedWerkBon, Mode=TwoWay}"
								 BorderThickness="0"
								 Background="Transparent">

							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="m:WerkBon">
									<Grid ColumnDefinitions="0.5*,1.8*,1.2*,1.1*,Auto"
										  Margin="0,2">
										<TextBlock Grid.Column="0"
												   Text="{Binding Id}"
												   FontWeight="Bold"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1"
												   Text="{Binding Offerte.Klant.Achternaam}"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2"
												   Text="{Binding Status}"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3"
												   Text="{Binding AangemaaktOp, StringFormat='dd/MM/yyyy'}"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<Button Grid.Column="4"
												Content="👁 Bekijk"
												Width="85"
												Padding="6,4"
												Background="#F5C242"
												Foreground="#222"
												FontWeight="Bold"
												CornerRadius="6"
												Cursor="Hand"
												Command="{Binding #Root.((vm:WerkBonLijstViewModel)DataContext).SelecteerWerkBonCommand}"
												CommandParameter="{Binding}"/>
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>

						</ListBox>
					</Border>

					<TextBlock Text="{Binding WerkBonnen.Count, StringFormat='Aantal werkbonnen: {0}'}"
							   Foreground="Black"
							   HorizontalAlignment="Center"/>

				</StackPanel>
			</ScrollViewer>

			<!-- DETAIL PANEL: lege staat -->
			<Border Grid.Column="1"
					Width="300"
					Padding="24"
					Background="White"
					CornerRadius="10"
					BorderBrush="#E0E0E0"
					BorderThickness="1"
					IsVisible="{Binding !IsDetailOpen}"
					VerticalAlignment="Top">
				<StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
					<TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center"/>
					<TextBlock Text="Klik op '👁 Bekijk' naast een werkbon om de details te openen."
							   Foreground="#666"
							   TextWrapping="Wrap"
							   TextAlignment="Center"
							   FontSize="13"/>
				</StackPanel>
			</Border>

			<!-- DETAIL PANEL: geselecteerde werkbon -->
			<Border Grid.Column="1"
					Width="520"
					Padding="24"
					Background="White"
					CornerRadius="10"
					BorderBrush="#E0E0E0"
					BorderThickness="1"
					IsVisible="{Binding IsDetailOpen}">

				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Spacing="14">

						<DockPanel>
							<TextBlock Text="📌 Werkbon details"
									   FontSize="22"
									   FontWeight="Bold"
									   Foreground="Black"
									   VerticalAlignment="Center"/>
							<Button DockPanel.Dock="Right"
									Content="✕ Sluiten"
									Command="{Binding SluitDetailCommand}"
									Background="Transparent"
									Foreground="#888"
									FontSize="12"
									Padding="6,4"
									VerticalAlignment="Center"
									HorizontalAlignment="Right"/>
						</DockPanel>

						<!-- Details -->
						<StackPanel Spacing="16">

							<Grid ColumnDefinitions="2*,3*"
								  RowDefinitions="Auto,Auto,Auto,Auto"
								  RowSpacing="7"
								  ColumnSpacing="14">

								<TextBlock Text="Bon nr."
										   Grid.Row="0" Grid.Column="0"
										   FontWeight="Bold"/>
								<TextBlock Text="{Binding SelectedWerkBon.Id}"
										   Grid.Row="0" Grid.Column="1"/>

								<TextBlock Text="Klant"
										   Grid.Row="1" Grid.Column="0"
										   FontWeight="Bold"/>
								<TextBlock Text="{Binding SelectedWerkBon.Offerte.Klant.Achternaam}"
										   Grid.Row="1" Grid.Column="1"/>

								<TextBlock Text="Werkbon status"
										   Grid.Row="2" Grid.Column="0"
										   FontWeight="Bold"/>
								<ComboBox Grid.Row="2" Grid.Column="1"
										  ItemsSource="{Binding WerkBonStatusOpties}"
										  SelectedItem="{Binding SelectedWerkBonStatus, Mode=TwoWay}"/>

							</Grid>

							<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
								<Button Content="📄 Open bestelbon"
										Command="{Binding OpenBestelBonCommand}"
										Background="#E8F4FD"
										Foreground="#1565C0"
										FontWeight="Bold"
										CornerRadius="6"
										Padding="12,6"/>
								<Button Content="💾 Opslaan status"
										Command="{Binding SaveStatusCommand}"
										Classes="MainBtn"
										Padding="12,6"/>
							</StackPanel>

							<TextBlock Text="🛠 Werktaken"
									   FontSize="18"
									   FontWeight="SemiBold"
									   Foreground="Black"/>

							<Border Background="#FAFAFA"
									BorderBrush="#DDD"
									BorderThickness="1"
									CornerRadius="8"
									Padding="6">

								<ListBox ItemsSource="{Binding SelectedWerkBonTaken}"
										 BorderThickness="0"
										 Background="Transparent">
									<ListBox.ItemTemplate>
										<DataTemplate x:DataType="m:WerkTaak">
											<Border Background="White"
													CornerRadius="8"
													BorderBrush="#EEE"
													BorderThickness="1"
													Padding="10"
													Margin="0,0,0,8">
												<StackPanel Spacing="6">
													<!-- Vaste info -->
													<TextBlock Text="{Binding Omschrijving}" FontWeight="Bold" Foreground="Black"/>
													<TextBlock Text="{Binding DuurMinuten, StringFormat='Duur: {0} min'}" Foreground="#555"/>
													<TextBlock Text="{Binding GeplandVan, StringFormat='Van: {0:dd/MM HH:mm}'}" Foreground="#555"/>
													<TextBlock Text="{Binding GeplandTot, StringFormat='Tot: {0:dd/MM HH:mm}'}" Foreground="#555"/>
													<TextBlock Text="{Binding OfferteRegel.TypeLijst.Artikelnummer, StringFormat='Lijst: {0}'}" Foreground="#555"/>

													<!-- Besteld badge -->
													<Border Background="#D1FAE5" CornerRadius="6" Padding="8,5"
													        IsVisible="{Binding IsBesteld}">
														<StackPanel Orientation="Horizontal" Spacing="6">
														<TextBlock Text="✅ Besteld op" Foreground="#065F46" FontWeight="SemiBold" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding BestelDatum, StringFormat='dd/MM/yyyy'}" Foreground="#065F46" FontWeight="SemiBold" VerticalAlignment="Center"/>
														</StackPanel>
													</Border>

													<!-- Op voorraad badge -->
													<Border Background="#D1FAE5" CornerRadius="6" Padding="8,5"
													        IsVisible="{Binding IsOpVoorraad}">
														<TextBlock Text="✅ Op voorraad — geen bestelling nodig"
														           Foreground="#065F46" FontWeight="SemiBold"/>
													</Border>

													<!-- Bestelling vereist + input -->
													<StackPanel Spacing="4" IsVisible="{Binding KanBesteldWorden}">
														<Border Background="#FEF3C7" CornerRadius="6" Padding="8,5">
															<TextBlock Text="⚠️ Bestelling vereist" Foreground="#92400E" FontWeight="SemiBold"/>
														</Border>
														<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
															<Button Content="Maak bestelling"
																	Background="#F5C242" Foreground="Black" FontWeight="Bold"
																	Command="{Binding #Root.((vm:WerkBonLijstViewModel)DataContext).MarkeerLijstAlsBesteldCommand}"
																	CommandParameter="{Binding}"/>
															<TextBlock Text="{Binding BestelDatum, StringFormat='Besteld op: {0:dd/MM/yyyy}'}"
																	   VerticalAlignment="Center"
																	   Foreground="#065F46"
																	   FontWeight="SemiBold"
																	   IsVisible="{Binding IsBesteld}"/>
														</StackPanel>
													</StackPanel>
												</StackPanel>
											</Border>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Border>

						</StackPanel>

					</StackPanel>
				</ScrollViewer>
			</Border>

		</Grid>
	</Grid>


</UserControl>
