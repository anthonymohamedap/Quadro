<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:QuadroApp.Converters"
    x:Class="QuadroApp.Views.WerkBonLijstView"
    x:Name="Root"
    x:DataType="vm:WerkBonLijstViewModel"
    d:DataContext="{d:DesignInstance vm:WerkBonLijstViewModel, IsDesignTimeCreatable=True}"
    Background="{DynamicResource SurfaceMuted}">

	<!-- Resources -->
	<UserControl.Resources>
		<conv:JaarConverter x:Key="JaarConv"/>
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*">

		<!-- HEADER -->
		<controls:QuadroHeader Grid.Row="0" Title="WERKBONNEN" BackCommand="{Binding GaTerugCommand}"/>

		<!-- MAIN -->
		<Grid Grid.Row="1"
			  Margin="20"
			  ColumnDefinitions="*,Auto"
			  ColumnSpacing="20">

			<!-- LINKS -->
			<ScrollViewer Grid.Column="0"
						  VerticalScrollBarVisibility="Auto"
						  HorizontalScrollBarVisibility="Disabled">

				<StackPanel Spacing="14">

					<TextBlock Text="🧾 Werkbonnen"
							   Classes="h1"/>

					<!-- Search + tools -->
					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

						<StackPanel Grid.Column="0"
									Orientation="Horizontal"
									Spacing="8"
									VerticalAlignment="Center">
							<TextBox MinWidth="180"
									 Foreground="{DynamicResource TextPrimary}"
									 Watermark="Zoek op bonnr of klant…"
									 Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
							<ComboBox ItemsSource="{Binding BeschikbareJaren}"
									  SelectedItem="{Binding GeselecteerdJaar, Mode=TwoWay}"
									  MinWidth="100"
									  VerticalAlignment="Center">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Converter={StaticResource JaarConv}}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>

						<StackPanel Grid.Column="1"
									Orientation="Horizontal"
									Spacing="6"
									VerticalAlignment="Center">
							<Button Content="🔄 Ververs"
									ToolTip.Tip="Ververs"
									Command="{Binding RefreshCommand}"
									Classes="MainBtn"/>
							<Button Content="📅 Planning openen"
									ToolTip.Tip="Planning openen"
									Command="{Binding OpenPlanningCommand}"
									Classes="MainBtn"/>
						</StackPanel>

					</Grid>

					<!-- Headers -->
					<Grid ColumnDefinitions="0.5*,1.8*,1.2*,1.1*,90">
						<TextBlock Text="Bon" Grid.Column="0" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
						<TextBlock Text="Klant" Grid.Column="1" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
						<TextBlock Text="Status" Grid.Column="2" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
						<TextBlock Text="Aangemaakt" Grid.Column="3" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
					</Grid>

					<Border Background="{DynamicResource Surface}"
							BorderBrush="{DynamicResource BorderSubtle}"
							BorderThickness="1"
							CornerRadius="8"
							Padding="4">

						<ListBox ItemsSource="{Binding WerkBonnen}"
								 SelectedItem="{Binding SelectedWerkBon, Mode=TwoWay}"
								 BorderThickness="0"
								 Background="Transparent">

							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="m:WerkBon">
									<Grid ColumnDefinitions="0.5*,1.8*,1.2*,1.1*,90"
										  Margin="0,2">
										<TextBlock Grid.Column="0"
												   Text="{Binding Id}"
												   FontWeight="Bold"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1"
												   Text="{Binding Offerte.Klant.Achternaam}"
												   ToolTip.Tip="{Binding Offerte.Klant.Achternaam}"
												   TextTrimming="CharacterEllipsis"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2"
												   Text="{Binding Status}"
												   TextTrimming="CharacterEllipsis"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3"
												   Text="{Binding AangemaaktOp, StringFormat='dd/MM/yyyy'}"
												   TextTrimming="CharacterEllipsis"
												   TextAlignment="Center"
												   VerticalAlignment="Center"/>
										<Button Grid.Column="4"
												Content="👁 Bekijk"
												Padding="6,4"
												Classes="AccentBtn"
												Cursor="Hand"
												Command="{Binding #Root.((vm:WerkBonLijstViewModel)DataContext).SelecteerWerkBonCommand}"
												CommandParameter="{Binding}"/>
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>

						</ListBox>
					</Border>

					<TextBlock Text="{Binding WerkBonnen.Count, StringFormat='Aantal werkbonnen: {0}'}"
							   Foreground="{DynamicResource TextPrimary}"
							   HorizontalAlignment="Center"/>

				</StackPanel>
			</ScrollViewer>

			<!-- DETAIL PANEL: lege staat -->
			<Border Grid.Column="1"
					MinWidth="240"
					MaxWidth="300"
					Padding="24"
					Background="{DynamicResource Surface}"
					CornerRadius="10"
					BorderBrush="{DynamicResource BorderSubtle}"
					BorderThickness="1"
					IsVisible="{Binding !IsDetailOpen}"
					VerticalAlignment="Top">
				<StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
					<TextBlock Text="📋" Classes="iconLarge" HorizontalAlignment="Center"/>
					<TextBlock Text="Klik op '👁 Bekijk' naast een werkbon om de details te openen."
							   Foreground="{DynamicResource TextSecondary}"
							   TextWrapping="Wrap"
							   TextAlignment="Center"
							   Classes="body"/>
				</StackPanel>
			</Border>

			<!-- DETAIL PANEL: geselecteerde werkbon -->
			<Border Grid.Column="1"
					MinWidth="360"
					MaxWidth="520"
					Padding="24"
					Background="{DynamicResource Surface}"
					CornerRadius="10"
					BorderBrush="{DynamicResource BorderSubtle}"
					BorderThickness="1"
					IsVisible="{Binding IsDetailOpen}">

				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Spacing="14">

						<DockPanel>
							<Button DockPanel.Dock="Right"
									Content="✕ Sluiten"
									Command="{Binding SluitDetailCommand}"
									Background="Transparent"
									Foreground="{DynamicResource TextSecondary}"
									Padding="6,4"
									VerticalAlignment="Center"
									HorizontalAlignment="Right"/>
							<TextBlock Text="📌 Werkbon details"
									   Classes="h1"
									   TextTrimming="CharacterEllipsis"
									   VerticalAlignment="Center"/>
						</DockPanel>

						<!-- Details -->
						<StackPanel Spacing="16">

							<Grid ColumnDefinitions="2*,3*"
								  RowDefinitions="Auto,Auto,Auto,Auto"
								  RowSpacing="7"
								  ColumnSpacing="14">

								<TextBlock Text="Bon nr."
										   Grid.Row="0" Grid.Column="0"
										   FontWeight="Bold"/>
								<TextBlock Text="{Binding SelectedWerkBon.Id}"
										   Grid.Row="0" Grid.Column="1"/>

								<TextBlock Text="Klant"
										   Grid.Row="1" Grid.Column="0"
										   FontWeight="Bold"/>
								<TextBlock Text="{Binding SelectedWerkBon.Offerte.Klant.Achternaam}"
										   ToolTip.Tip="{Binding SelectedWerkBon.Offerte.Klant.Achternaam}"
										   TextTrimming="CharacterEllipsis"
										   Grid.Row="1" Grid.Column="1"/>

								<TextBlock Text="Werkbon status"
										   Grid.Row="2" Grid.Column="0"
										   FontWeight="Bold"/>
								<ComboBox Grid.Row="2" Grid.Column="1"
										  ItemsSource="{Binding WerkBonStatusOpties}"
										  SelectedItem="{Binding SelectedWerkBonStatus, Mode=TwoWay}"/>

							</Grid>

							<WrapPanel HorizontalAlignment="Right">
								<Button Content="📄 Open bestelbon"
										Command="{Binding OpenBestelBonCommand}"
										Background="{DynamicResource InfoBg}"
										Foreground="{DynamicResource InfoText}"
										FontWeight="Bold"
										CornerRadius="6"
										Padding="12,6"
										Margin="0,0,10,6"/>
								<Button Content="💾 Opslaan status"
										Command="{Binding SaveStatusCommand}"
										Classes="MainBtn"
										Padding="12,6"
										Margin="0,0,0,6"/>
							</WrapPanel>

							<TextBlock Text="🛠 Werktaken"
									   Classes="h2"/>

							<Border Background="{DynamicResource SurfaceMutedAlt}"
									BorderBrush="{DynamicResource BorderSubtle}"
									BorderThickness="1"
									CornerRadius="8"
									Padding="6">

								<ListBox ItemsSource="{Binding SelectedWerkBonTaken}"
										 BorderThickness="0"
										 Background="Transparent">
									<ListBox.ItemTemplate>
										<DataTemplate x:DataType="m:WerkTaak">
											<Border Background="{DynamicResource Surface}"
													CornerRadius="8"
													BorderBrush="{DynamicResource BorderSubtle}"
													BorderThickness="1"
													Padding="10"
													Margin="0,0,0,8">
												<StackPanel Spacing="6">
													<!-- Vaste info -->
													<TextBlock Text="{Binding Omschrijving}"
															   FontWeight="Bold"
															   Foreground="{DynamicResource TextPrimary}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding Omschrijving}"/>
													<TextBlock Text="{Binding DuurMinuten, StringFormat='Duur: {0} min'}" Foreground="{DynamicResource TextSecondary}"/>
													<TextBlock Text="{Binding GeplandVan, StringFormat='Van: {0:dd/MM HH:mm}'}" Foreground="{DynamicResource TextSecondary}"/>
													<TextBlock Text="{Binding GeplandTot, StringFormat='Tot: {0:dd/MM HH:mm}'}" Foreground="{DynamicResource TextSecondary}"/>
													<TextBlock Text="{Binding OfferteRegel.TypeLijst.Artikelnummer, StringFormat='Lijst: {0}'}"
															   Foreground="{DynamicResource TextSecondary}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding OfferteRegel.TypeLijst.Artikelnummer}"/>

													<!-- Besteld badge -->
													<Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="8,5"
													        IsVisible="{Binding IsBesteld}">
														<StackPanel Orientation="Horizontal" Spacing="6">
														<TextBlock Text="✅ Besteld op" Foreground="{DynamicResource Success}" FontWeight="SemiBold" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding BestelDatum, StringFormat='dd/MM/yyyy'}" Foreground="{DynamicResource Success}" FontWeight="SemiBold" VerticalAlignment="Center"/>
														</StackPanel>
													</Border>

													<!-- Op voorraad badge -->
													<Border Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="8,5"
													        IsVisible="{Binding IsOpVoorraad}">
														<TextBlock Text="✅ Op voorraad — geen bestelling nodig"
														           Foreground="{DynamicResource Success}"
														           FontWeight="SemiBold"
														           TextWrapping="Wrap"/>
													</Border>

													<!-- Bestelling vereist + input -->
													<StackPanel Spacing="4" IsVisible="{Binding KanBesteldWorden}">
														<Border Background="{DynamicResource WarningBg}" CornerRadius="6" Padding="8,5">
															<TextBlock Text="⚠️ Bestelling vereist" Foreground="{DynamicResource Warning}" FontWeight="SemiBold"/>
														</Border>
														<StackPanel Spacing="4">
															<WrapPanel>
																<TextBlock Text="Bestelwijze:" VerticalAlignment="Center" Classes="caption" Margin="0,0,12,4"/>
																<RadioButton Content="In verstek"
																		 GroupName="{Binding Id, StringFormat='BVT{0}'}"
																		 IsChecked="{Binding BestelVormIsVerstek, Mode=TwoWay}"
																		 Margin="0,0,12,4"/>
																<RadioButton Content="In lengte"
																		 GroupName="{Binding Id, StringFormat='BVT{0}'}"
																		 IsChecked="{Binding BestelVormIsInLengte, Mode=TwoWay}"
																		 Margin="0,0,12,4"/>
																<RadioButton Content="Gemonteerd"
																		 GroupName="{Binding Id, StringFormat='BVT{0}'}"
																		 IsChecked="{Binding BestelVormIsGemonteerd, Mode=TwoWay}"
																		 Margin="0,0,0,4"/>
															</WrapPanel>
															<Button Content="Maak bestelling"
																	Classes="AccentBtn"
																	Command="{Binding #Root.((vm:WerkBonLijstViewModel)DataContext).MarkeerLijstAlsBesteldCommand}"
																	CommandParameter="{Binding}"/>
															<TextBlock Text="{Binding BestelDatum, StringFormat='Besteld op: {0:dd/MM/yyyy}'}"
																	   VerticalAlignment="Center"
																	   Foreground="{DynamicResource Success}"
																	   FontWeight="SemiBold"
																	   IsVisible="{Binding IsBesteld}"/>
														</StackPanel>
													</StackPanel>
												</StackPanel>
											</Border>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Border>

						</StackPanel>

					</StackPanel>
				</ScrollViewer>
			</Border>

		</Grid>
	</Grid>


</UserControl>
