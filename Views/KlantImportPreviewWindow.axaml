<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.KlantImportPreviewWindow"
        x:DataType="vm:KlantExcelPreviewViewModel"
        Width="900"
        Height="600"
        MinWidth="700"
        MinHeight="440"
        CanResize="True"
        Title="Excel-import"
        Background="{DynamicResource SurfaceMuted}">


	<DockPanel Margin="12">

		<!-- Buttons -->
		<StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
			<Button Content="Annuleren"
                    MinWidth="100"
                    Command="{Binding CancelCommand}" />

			<Button Content="Importeren"
                    MinWidth="110"
                    IsEnabled="{Binding CanImport}"
                    Command="{Binding ConfirmCommand}" />
		</StackPanel>

		<!-- DataGrid -->
		<DataGrid ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="All">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Voornaam"
                                    Width="*"
                                    MinWidth="100"
                                    Binding="{Binding Voornaam}" />

				<DataGridTextColumn Header="Achternaam"
                                    Width="*"
                                    MinWidth="120"
                                    Binding="{Binding Achternaam}" />

				<DataGridTextColumn Header="E-mail"
                                    Width="1.5*"
                                    MinWidth="140"
                                    Binding="{Binding Email}" />

				<DataGridTextColumn Header="Status"
                                    Width="1.5*"
                                    MinWidth="120"
                                    Binding="{Binding ValidationMessage}" />
			</DataGrid.Columns>
		</DataGrid>

	</DockPanel>
</Window>
