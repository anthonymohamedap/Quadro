<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:conv="using:QuadroApp.Converters"
    x:Class="QuadroApp.Views.LijstenView"
    x:DataType="vm:LijstenViewModel"
    d:DataContext="{d:DesignInstance vm:LijstenViewModel, IsDesignTimeCreatable=True}"
    Background="{DynamicResource SurfaceMuted}">

    <UserControl.Resources>
        <conv:BoolToThicknessConverter x:Key="BoolToThicknessSlide"
                                       WhenTrue="0"
                                       WhenFalse="0,0,-540,0"/>
        <conv:BoolToThicknessConverter x:Key="BoolToMainShift"
                                       WhenTrue="0,0,540,0"
                                       WhenFalse="0"/>
        <conv:BoolToDoubleConverter x:Key="BoolToOpacity"
                                    WhenTrue="1"
                                    WhenFalse="0"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <controls:QuadroHeader Title="LIJSTENBEHEER" BackCommand="{Binding GaTerugCommand}"/>

        <Grid Grid.Row="1" Margin="24">

            <!-- Star-rij zodat de lijst de resthoogte vult en zelf scrolt -->
            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="12"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  MaxWidth="850">

                <Grid.Transitions>
                    <Transitions>
                        <ThicknessTransition Property="Margin" Duration="0:0:0.25"/>
                    </Transitions>
                </Grid.Transitions>
                <Grid.Margin>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToMainShift}"/>
                </Grid.Margin>

                <TextBlock Text="TypeLijsten" Classes="h1" TextTrimming="CharacterEllipsis"/>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">

                    <TextBox Grid.Column="0"
                             MinWidth="220"
                             Watermark="Zoek op artikelnummer of leverancier..."
                             Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="➕ Nieuw" Command="{Binding NieuwCommand}" Classes="MainBtn" Margin="0,0,6,6" IsVisible="{Binding MagPrijzenWijzigen}"/>
                        <Button Content="🗑️ Verwijderen" Command="{Binding DeleteCommand}" Classes="MainBtn" Margin="0,0,6,6" IsVisible="{Binding MagPrijzenWijzigen}"/>
                        <Button Content="💾 Opslaan" Command="{Binding SaveCommand}" Classes="MainBtn" Margin="0,0,6,6" IsVisible="{Binding MagPrijzenWijzigen}"/>
                        <Button Content="🔄 Ververs" Command="{Binding RefreshCommand}" Classes="MainBtn" Margin="0,0,6,6"/>
                        <Button Content="📥 Excel-import" Command="{Binding ImportExcelCommand}" Classes="MainBtn" Margin="0,0,6,6" IsVisible="{Binding MagPrijzenWijzigen}"/>
                        <Button Content="🧩 Bulk bijwerken" Command="{Binding BulkPrijsUpdateCommand}" Classes="MainBtn" Margin="0,0,0,6" IsVisible="{Binding MagPrijzenWijzigen}"/>
                    </WrapPanel>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Content="Vorige"
                            Command="{Binding PrevPageCommand}"
                            Classes="MainBtn"/>
                    <Button Content="Volgende"
                            Command="{Binding NextPageCommand}"
                            Classes="MainBtn"/>
                </StackPanel>

                <Border Grid.Row="3"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="0">

                    <Grid RowDefinitions="Auto,*">
                        <Border Background="{DynamicResource SurfaceHeader}"
                                Padding="10,6"
                                BorderBrush="{DynamicResource BorderSubtle}"
                                BorderThickness="0,0,0,1">

                            <Grid ColumnDefinitions="1.2*,1.3*,0.8*,0.9*,0.8*,2.2*"
                                  ColumnSpacing="12">

                                <TextBlock Text="Artikelnummer" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1" Text="Leverancier" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="Breedte" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3" Text="Voorraad" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="4" Text="Minimum" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="5" Text="Opmerking" Classes="label" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1"
                                 x:Name="LijstenList"
                                 ItemsSource="{Binding PagedLijsten}"
                                 SelectedItem="{Binding GeselecteerdeLijst, Mode=TwoWay}"
                                 SelectionMode="Multiple"
                                 SelectionChanged="LijstenList_SelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:TypeLijst">

                                    <Border Padding="10,6">
                                        <Grid ColumnDefinitions="1.2*,1.3*,0.8*,0.9*,0.8*,2.2*"
                                              ColumnSpacing="12">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Artikelnummer}"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Artikelnummer}"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Leverancier.Naam}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Leverancier.Naam}"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BreedteCm}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding VoorraadMeter, StringFormat='{}{0:0.##} m'}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding MinimumVoorraad, StringFormat='{}{0:0.##} m'}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Opmerking}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Opmerking}"/>
                                        </Grid>
                                    </Border>

                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </Grid>

                </Border>

                <TextBlock Grid.Row="4"
                           Text="{Binding AantalLijsten, StringFormat='Aantal geladen lijsten: {0}'}"
                           Classes="caption"
                           HorizontalAlignment="Center"/>
            </Grid>

            <Border Width="520"
                    Padding="24"
                    Background="{DynamicResource Surface}"
                    CornerRadius="10"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsHitTestVisible="{Binding IsDetailOpen}">

                <Border.Transitions>
                    <Transitions>
                        <ThicknessTransition Property="Margin" Duration="0:0:0.2"/>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                    </Transitions>
                </Border.Transitions>

                <Border.Margin>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToThicknessSlide}"/>
                </Border.Margin>
                <Border.Opacity>
                    <Binding Path="IsDetailOpen" Converter="{StaticResource BoolToOpacity}"/>
                </Border.Opacity>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Lijstdetails" Classes="h1" TextTrimming="CharacterEllipsis"/>

                        <Border Background="{DynamicResource WarningBg}"
                                CornerRadius="8"
                                Padding="10"
                                IsVisible="{Binding !IsDetailOpen}">
                            <TextBlock Text="Selecteer links een lijst om details te zien."
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel x:DataType="vm:LijstenViewModel"
                                    Spacing="18"
                                    IsVisible="{Binding IsDetailOpen}">

                            <Grid ColumnDefinitions="2*,3*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="7"
                                  ColumnSpacing="15">

                                <TextBlock Text="Artikelnummer" Grid.Row="0" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.Artikelnummer, Mode=TwoWay}" Grid.Row="0" Grid.Column="1"/>

                                <TextBlock Text="Levcode" Grid.Row="1" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.Levcode, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>

                                <TextBlock Text="Leverancier" Grid.Row="2" Grid.Column="0" Classes="label" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
                                    <Border Background="{DynamicResource InfoBg}"
                                            CornerRadius="6"
                                            Padding="6">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InfoText}"
                                                   Text="{Binding SelectedLeverancier.Naam, TargetNullValue='Geen leverancier geselecteerd'}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding SelectedLeverancier.Naam}"/>
                                    </Border>

                                    <TextBox Watermark="Zoek leverancier..."
                                             Text="{Binding LeverancierZoekterm, UpdateSourceTrigger=PropertyChanged}"/>

                                    <ComboBox ItemsSource="{Binding GefilterdeLeveranciers}"
                                              SelectedItem="{Binding SelectedLeverancier, Mode=TwoWay}"
                                              MaxDropDownHeight="250">

                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="m:Leverancier">
                                                <TextBlock TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Naam}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>

                                    </ComboBox>
                                </StackPanel>

                                <TextBlock Text="Breedte" Grid.Row="3" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.BreedteCm, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>

                                <TextBlock Text="Soort" Grid.Row="4" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.Soort, Mode=TwoWay}" Grid.Row="4" Grid.Column="1"/>

                                <TextBlock Text="Voorraad" Grid.Row="5" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.VoorraadMeter, Mode=TwoWay}" Grid.Row="5" Grid.Column="1"/>

                                <TextBlock Text="Minimum Voorraad" Grid.Row="6" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.MinimumVoorraad, Mode=TwoWay}" Grid.Row="6" Grid.Column="1"/>

                                <TextBlock Text="InventarisKost" Grid.Row="7" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.InventarisKost, Mode=TwoWay}" Grid.Row="7" Grid.Column="1"/>

                                <TextBlock Text="PrijsPerMeter" Grid.Row="8" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.PrijsPerMeter, Mode=TwoWay}" Grid.Row="8" Grid.Column="1"/>

                                <TextBlock Text="Winstfactor" Grid.Row="9" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.WinstFactor, Mode=TwoWay}" Grid.Row="9" Grid.Column="1"/>

                                <TextBlock Text="Afvalpercentage" Grid.Row="10" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.AfvalPercentage, Mode=TwoWay}" Grid.Row="10" Grid.Column="1"/>

                                <TextBlock Text="VasteKost" Grid.Row="11" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.VasteKost, Mode=TwoWay}" Grid.Row="11" Grid.Column="1"/>

                                <TextBlock Text="WerkMinuten" Grid.Row="12" Grid.Column="0" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBox Foreground="{DynamicResource TextPrimary}" Text="{Binding GeselecteerdeLijst.WerkMinuten, Mode=TwoWay}" Grid.Row="12" Grid.Column="1"/>

                                <TextBlock Text="Opmerking" Grid.Row="13" Grid.Column="0" Classes="label" VerticalAlignment="Top" TextTrimming="CharacterEllipsis"/>
                                <TextBox Grid.Row="13"
                                         Grid.Column="1"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Text="{Binding GeselecteerdeLijst.Opmerking, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         MinHeight="120"/>

                            </Grid>

                            <StackPanel HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="4">
                                <Button Content="Opslaan wijzigingen"
                                        Command="{Binding SaveCommand}"
                                        Classes="MainBtn"
                                        Padding="16,6"
                                        IsVisible="{Binding MagPrijzenWijzigen}"/>
                                <TextBlock Classes="caption"
                                           Text="Alleen een beheerder kan lijsten/prijzen wijzigen."
                                           IsVisible="{Binding !MagPrijzenWijzigen}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            </Border>

        </Grid>
    </Grid>
</UserControl>
