<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
             xmlns:vm="using:QuadroApp.ViewModels"
             xmlns:conv="clr-namespace:QuadroApp.Converters"
             x:Class="QuadroApp.Views.FacturenView"
             x:DataType="vm:FacturenViewModel"
             Background="{DynamicResource SurfaceMutedAlt}"
             Foreground="{DynamicResource TextPrimary}">

  <Grid RowDefinitions="Auto,*">

    <!-- ░░ HEADER ░░ -->
    <controls:QuadroHeader Grid.Row="0" Title="FACTUREN" BackCommand="{Binding GaTerugCommand}"/>

    <!-- ░░ MAIN CONTENT ░░
         Beide kolommen zijn star-gesized met interne scrollregio's:
         de lijsten vullen de resthoogte en scrollen zelf, zodat niets clippt. -->
    <Grid Grid.Row="1" ColumnDefinitions="1.1*,1.4*" Margin="24" ColumnSpacing="16">

      <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <TextBlock Text="Bestelbonnen" Classes="h1" TextTrimming="CharacterEllipsis"/>
        <TextBox Grid.Row="1" Watermark="Filter op nummer / klant / status" Text="{Binding FilterTekst, Mode=TwoWay}"/>
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Facturen}"
                 SelectedItem="{Binding GeselecteerdeFactuur, Mode=TwoWay}"
                 MinHeight="120">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="1.2*,2*,1*" Margin="4">
                <TextBlock Text="{Binding FactuurNummer}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Text="{Binding KlantNaam}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding KlantNaam}"/>
                <TextBlock Grid.Column="2" Text="{Binding Status}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>

      <Border Grid.Column="1"
              Background="{DynamicResource Surface}"
              BorderBrush="{DynamicResource BorderSubtle}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
          <TextBlock Text="Bestelbon details" Classes="h2" TextTrimming="CharacterEllipsis"/>

          <Grid Grid.Row="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
            <TextBlock Text="Besteldatum" VerticalAlignment="Center"/>
            <DatePicker Grid.Column="1" SelectedDate="{Binding FactuurDatum, Mode=TwoWay}" IsEnabled="{Binding IsDraft}"/>

            <TextBlock Grid.Row="1" Text="Vervaldatum" VerticalAlignment="Center"/>
            <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding VervalDatum, Mode=TwoWay}" IsEnabled="{Binding IsDraft}"/>

            <TextBlock Grid.Row="2" Text="Opmerking" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Opmerking, Mode=TwoWay}" IsEnabled="{Binding IsDraft}"/>

            <TextBlock Grid.Row="3" Text="Initialen" VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding AangenomenDoorInitialen, Mode=TwoWay}" IsEnabled="{Binding IsDraft}"/>
          </Grid>

          <Border Grid.Row="2"
                  BorderBrush="{DynamicResource BorderSubtle}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Background="{DynamicResource SurfaceMutedAlt}"
                  MinHeight="120"
                  Padding="6">
            <ListBox ItemsSource="{Binding Lijnen}" BorderThickness="0" Background="Transparent">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="2.6*,0.7*,0.9*,0.7*,0.9*" Margin="0,2">
                    <TextBlock Text="{Binding Omschrijving, Converter={x:Static conv:FactuurOmschrijvingConverter.Instance}}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Column="1" Text="{Binding Aantal}" HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="2" Text="{Binding PrijsExcl}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="3" Text="{Binding BtwPct}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="4" Text="{Binding TotaalIncl}" HorizontalAlignment="Right" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Border>

          <WrapPanel Grid.Row="3">
            <Button Classes="AccentBtn" Content="Opslaan" Command="{Binding SaveCommand}" Margin="0,0,8,6" Padding="12,8"/>
            <Button Classes="AccentBtn" Content="Markeer als klaar voor export" Command="{Binding MarkeerKlaarVoorExportCommand}" Margin="0,0,8,6" Padding="12,8"/>
            <Button Classes="AccentBtn" Content="Export PDF" Command="{Binding ExportPdfCommand}" Margin="0,0,8,6" Padding="12,8"/>
            <Button Classes="AccentBtn" Content="Markeer Betaald" Command="{Binding MarkeerBetaaldCommand}" Margin="0,0,0,6" Padding="12,8"/>
          </WrapPanel>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</UserControl>
