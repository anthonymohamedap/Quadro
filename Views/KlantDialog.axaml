<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:QuadroApp.Model.DB"
        x:Class="QuadroApp.Views.KlantDialog"
        x:DataType="m:Klant"
        Width="460"
        Height="620"
        MinWidth="400"
        MinHeight="460"
        CanResize="True"
        Title="Klantgegevens"
        Background="{DynamicResource SurfaceMuted}">

	<Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="10" Background="{DynamicResource Surface}" Margin="12">
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="16" Spacing="8">

				<TextBlock Text="Klantgegevens"
						   Classes="h1"
						   Margin="0,0,0,12"/>

				<TextBox Watermark="Voornaam"   Text="{Binding Voornaam, Mode=TwoWay}"/>
				<TextBox Watermark="Achternaam" Text="{Binding Achternaam, Mode=TwoWay}"/>

				<TextBox Watermark="E-mail"   Text="{Binding Email, Mode=TwoWay}"/>
				<TextBox Watermark="Telefoon" Text="{Binding Telefoon, Mode=TwoWay}"/>

				<TextBox Watermark="Straat"   Text="{Binding Straat, Mode=TwoWay}"/>
				<TextBox Watermark="Nummer"   Text="{Binding Nummer, Mode=TwoWay}"/>
				<TextBox Watermark="Postcode" Text="{Binding Postcode, Mode=TwoWay}"/>
				<TextBox Watermark="Gemeente" Text="{Binding Gemeente, Mode=TwoWay}"/>

				<TextBox Watermark="BTW-nummer (bv. BE0123456789)" Text="{Binding BtwNummer, Mode=TwoWay}"/>

				<TextBox Watermark="Opmerking"
						 Text="{Binding Opmerking, Mode=TwoWay}"
						 AcceptsReturn="True"
						 TextWrapping="Wrap"
						 MinHeight="90"/>

				<StackPanel Orientation="Horizontal"
							Spacing="8"
							Margin="0,16,0,0"
							HorizontalAlignment="Right">

					<Button Content="Annuleren"
							MinWidth="110"
							Background="{DynamicResource BorderSubtle}"
							Foreground="{DynamicResource TextPrimary}"
							CornerRadius="8"
							Click="Annuleren_Click"/>

					<Button Content="Opslaan"
							MinWidth="110"
							Background="{DynamicResource BrandDark}"
							Foreground="{DynamicResource TextOnDark}"
							FontWeight="Bold"
							CornerRadius="8"
							Click="Opslaan_Click"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Border>
</Window>
