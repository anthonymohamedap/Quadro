<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:QuadroApp.ViewModels"
    xmlns:m="clr-namespace:QuadroApp.Model.DB"
    xmlns:conv="clr-namespace:QuadroApp.Converters"
    x:Class="QuadroApp.Views.FactuurPreviewWindow"
    x:DataType="vm:FactuurPreviewViewModel"
    Width="860"
    Height="620"
    MinWidth="720"
    MinHeight="520"
    CanResize="True"
    Title="Bestelbon preview"
    WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource SurfaceMutedAlt}">
        <Border Grid.Row="0" Background="{DynamicResource BrandDark}" Padding="18">
            <StackPanel>
                <TextBlock Text="{Binding Titel}" Classes="h2" Foreground="{DynamicResource TextOnDark}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Titel}"/>
                <TextBlock Text="{Binding StatusTekst}" Classes="body" Foreground="{DynamicResource TextMutedOnDark}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StatusTekst}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="18,18,18,0" Padding="14" Background="{DynamicResource InfoBg}" BorderBrush="{DynamicResource InfoBorder}" BorderThickness="1" CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock Text="De PDF-preview wordt geopend in je standaard PDF-viewer."
                           Classes="body"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource InfoText}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding PreviewPad}" Classes="caption" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="18" ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
            <Border Padding="14" Background="{DynamicResource Surface}" CornerRadius="10" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                <!-- Eenvoudige lijst-tabel (ItemsControl) i.p.v. DataGrid: rendert altijd,
                     onafhankelijk van het DataGrid-thema; lange omschrijvingen breken af. -->
                <Grid RowDefinitions="Auto,Auto,*">
                    <TextBlock Text="Bestelbonlijnen" Classes="h3" Margin="0,0,0,10"/>

                    <!-- Kopregel -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,60,90,100" Margin="0,0,0,2">
                        <TextBlock Text="Omschrijving" Classes="label" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="Aantal" Classes="label" Foreground="{DynamicResource TextSecondary}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="Prijs" Classes="label" Foreground="{DynamicResource TextSecondary}" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="Totaal" Classes="label" Foreground="{DynamicResource TextSecondary}" TextAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" Margin="0,4,0,0">
                        <ItemsControl ItemsSource="{Binding Lijnen}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:FactuurLijn">
                                    <Border BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="0,6">
                                        <Grid ColumnDefinitions="*,60,90,100">
                                            <TextBlock Text="{Binding Omschrijving, Converter={x:Static conv:FactuurOmschrijvingConverter.Instance}}"
                                                       Classes="body"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Aantal}" Classes="body"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="2" Text="{Binding PrijsExcl, StringFormat=€ {0:N2}}" Classes="body"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TotaalIncl, StringFormat=€ {0:N2}}" Classes="body"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" Background="{DynamicResource Surface}" CornerRadius="10" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Samenvatting" Classes="h3"/>
                        <TextBlock Text="{Binding Factuur.KlantNaam}" Classes="body" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Factuur.KlantNaam}"/>
                        <TextBlock Text="{Binding Factuur.KlantAdres}" Classes="body" TextWrapping="Wrap"/>
                        <Separator/>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                            <TextBlock Text="BestelBon datum" Classes="body"/>
                            <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.FactuurDatum, StringFormat={}{0:dd/MM/yyyy}}"/>

                            <TextBlock Grid.Row="1" Text="Vervaldatum" Classes="body"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Classes="body" Text="{Binding Factuur.VervalDatum, StringFormat={}{0:dd/MM/yyyy}}"/>

                            <TextBlock Grid.Row="2" Text="Initialen" Classes="body"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Classes="body" Text="{Binding Factuur.AangenomenDoorInitialen, TargetNullValue='-'}"/>
                        </Grid>
                        <Separator/>
                        <TextBlock Text="Opmerking" Classes="body" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Factuur.Opmerking, TargetNullValue='Geen extra opmerking'}"
                                   Classes="body"
                                   TextWrapping="Wrap"/>
                        <Separator/>

                        <!-- Totalen: altijd excl -> BTW -> incl; korting + voorschot conditioneel -->
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Subtotaal (excl. BTW)" Classes="body"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.BrutoExclBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !Factuur.IsBtwVrijgesteld}">
                                <TextBlock Text="BTW (21%)" Classes="body"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.BrutoBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Alleen bij korting: incl-subtotaal + kortingregel -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding Factuur.KortingPct, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                                <TextBlock Text="Subtotaal (incl. BTW)" Classes="body"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.BrutoInclBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding Factuur.KortingPct, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                                <TextBlock Text="{Binding Factuur.KortingPct, StringFormat='Korting {0:0.##}%'}" Classes="body" Foreground="{DynamicResource Danger}"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.KortingBedragExcl, StringFormat=- € {0:N2}}" Foreground="{DynamicResource Danger}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Totaal (incl. BTW)" Classes="body" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.TotaalInclBtw, StringFormat=€ {0:N2}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Alleen bij voorschot -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding Factuur.VoorschotBedrag, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                                <TextBlock Text="Voorschot betaald" Classes="body"/>
                                <TextBlock Grid.Column="1" Classes="body" Text="{Binding Factuur.VoorschotBedrag, StringFormat=- € {0:N2}}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Te betalen bij afhalen" Classes="h3"/>
                                <TextBlock Grid.Column="1" Classes="h3" Text="{Binding Factuur.RestTeBetalen, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1,1,1,0" Padding="18,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Open preview" MinWidth="110" Command="{Binding OpenPreviewCommand}"/>
                <Button Content="Opslaan bij offerte"
                        MinWidth="130"
                        Command="{Binding BewaarBijOfferteCommand}"
                        Background="{DynamicResource InfoBg}"
                        Foreground="{DynamicResource InfoText}"
                        FontWeight="Bold"/>
                <Button Content="Exporteer PDF"
                        MinWidth="120"
                        Command="{Binding ExporteerCommand}"
                        Classes="AccentBtn"/>
                <Button Content="Sluiten" MinWidth="90" Command="{Binding SluitCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
