<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:QuadroApp.ViewModels"
    xmlns:m="clr-namespace:QuadroApp.Model.DB"
    xmlns:conv="clr-namespace:QuadroApp.Converters"
    x:Class="QuadroApp.Views.FactuurPreviewWindow"
    x:DataType="vm:FactuurPreviewViewModel"
    Width="860"
    Height="620"
    MinWidth="760"
    MinHeight="520"
    Title="Bestelbon preview"
    WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#F7F8FA">
        <Border Grid.Row="0" Background="#123B68" Padding="18">
            <StackPanel>
                <TextBlock Text="{Binding Titel}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding StatusTekst}" Foreground="#D9EAFE"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="18,18,18,0" Padding="14" Background="#EEF4FB" CornerRadius="8">
            <StackPanel Spacing="8">
                <TextBlock Text="De PDF-preview wordt geopend in je standaard PDF-viewer."
                           FontWeight="SemiBold"
                           Foreground="#123B68"/>
                <TextBlock Text="{Binding PreviewPad}" TextWrapping="Wrap" Foreground="#38506A"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="18" ColumnDefinitions="1.2*,0.8*" ColumnSpacing="18">
            <Border Padding="14" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                <!-- Eenvoudige lijst-tabel (ItemsControl) i.p.v. DataGrid: rendert altijd,
                     onafhankelijk van het DataGrid-thema; lange omschrijvingen breken af. -->
                <Grid RowDefinitions="Auto,Auto,*">
                    <TextBlock Text="Bestelbonlijnen" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Kopregel -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,60,90,100" Margin="0,0,0,2">
                        <TextBlock Text="Omschrijving" FontWeight="SemiBold" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="1" Text="Aantal" FontWeight="SemiBold" Foreground="#6B7280" TextAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="Prijs" FontWeight="SemiBold" Foreground="#6B7280" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="Totaal" FontWeight="SemiBold" Foreground="#6B7280" TextAlignment="Right"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" Margin="0,4,0,0">
                        <ItemsControl ItemsSource="{Binding Lijnen}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:FactuurLijn">
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,6">
                                        <Grid ColumnDefinitions="*,60,90,100">
                                            <TextBlock Text="{Binding Omschrijving, Converter={x:Static conv:FactuurOmschrijvingConverter.Instance}}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Aantal}"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="2" Text="{Binding PrijsExcl, StringFormat=€ {0:N2}}"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TotaalIncl, StringFormat=€ {0:N2}}"
                                                       TextAlignment="Right" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Padding="14" Background="White" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="Samenvatting" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Factuur.KlantNaam}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Factuur.KlantAdres}" TextWrapping="Wrap"/>
                    <Separator/>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <TextBlock Text="BestelBon datum"/>
                        <TextBlock Grid.Column="1" Text="{Binding Factuur.FactuurDatum, StringFormat={}{0:dd/MM/yyyy}}"/>

                        <TextBlock Grid.Row="1" Text="Vervaldatum"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Factuur.VervalDatum, StringFormat={}{0:dd/MM/yyyy}}"/>

                        <TextBlock Grid.Row="2" Text="Initialen"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Factuur.AangenomenDoorInitialen, TargetNullValue='-'}"/>
                    </Grid>
                    <Separator/>
                    <TextBlock Text="Opmerking" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Factuur.Opmerking, TargetNullValue='Geen extra opmerking'}"
                               TextWrapping="Wrap"/>
                    <Separator/>

                    <!-- Totalen: altijd excl -> BTW -> incl; korting + voorschot conditioneel -->
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Subtotaal (excl. BTW)"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.BrutoExclBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !Factuur.IsBtwVrijgesteld}">
                            <TextBlock Text="BTW (21%)"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.BrutoBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Alleen bij korting: incl-subtotaal + kortingregel -->
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding Factuur.KortingPct, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                            <TextBlock Text="Subtotaal (incl. BTW)"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.BrutoInclBtw, StringFormat=€ {0:N2}}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding Factuur.KortingPct, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                            <TextBlock Text="{Binding Factuur.KortingPct, StringFormat='Korting {0:0.##}%'}" Foreground="#B91C1C"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.KortingBedragExcl, StringFormat=- € {0:N2}}" Foreground="#B91C1C" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Totaal (incl. BTW)" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.TotaalInclBtw, StringFormat=€ {0:N2}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Alleen bij voorschot -->
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding Factuur.VoorschotBedrag, Converter={x:Static conv:BooleanConverters.IsPositive}}">
                            <TextBlock Text="Voorschot betaald"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.VoorschotBedrag, StringFormat=- € {0:N2}}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Te betalen bij afhalen" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="{Binding Factuur.RestTeBetalen, StringFormat=€ {0:N2}}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,1,1,0" Padding="18">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Open preview" Command="{Binding OpenPreviewCommand}"/>
                <Button Content="Opslaan bij offerte"
                        Command="{Binding BewaarBijOfferteCommand}"
                        Background="#D9EAFE"
                        Foreground="#123B68"
                        FontWeight="Bold"/>
                <Button Content="Exporteer PDF"
                        Command="{Binding ExporteerCommand}"
                        Background="#F5C242"
                        Foreground="Black"
                        FontWeight="Bold"/>
                <Button Content="Sluiten" Command="{Binding SluitCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
