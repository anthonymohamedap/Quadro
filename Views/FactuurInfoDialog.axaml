<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:QuadroApp.ViewModels"
    x:Class="QuadroApp.Views.FactuurInfoDialog"
    x:DataType="vm:FactuurInfoDialogViewModel"
    Width="560"
    Height="430"
    MinWidth="480"
    MinHeight="400"
    CanResize="True"
    Title="Bestelbon gegevens"
    Background="{DynamicResource SurfaceMutedAlt}"
    WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Padding="20">
            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="Extra bestelbon info" Classes="h1"/>
                    <TextBlock Text="{Binding FactuurNummer}"
                               Classes="body"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource InfoText}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding FactuurNummer}"/>
                    <TextBlock Text="{Binding KlantNaam}"
                               Classes="body"
                               Foreground="{DynamicResource TextSecondary}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding KlantNaam}"/>
                </StackPanel>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Classes="body" Text="Besteldatum"/>
                    <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding FactuurDatum, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Classes="body" Text="Vervaldatum"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding VervalDatum, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Classes="body" Text="Initialen"/>
                    <TextBox Grid.Row="2" Grid.Column="1" MaxLength="10" Text="{Binding AangenomenDoorInitialen, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" Classes="body" Text="Opmerking"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             MinHeight="100"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             Text="{Binding Opmerking, Mode=TwoWay}"/>
                </Grid>

                <Border Background="{DynamicResource DangerBg}"
                        BorderBrush="{DynamicResource Danger}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        IsVisible="{Binding HasValidatieFout}">
                    <TextBlock Text="{Binding ValidatieFout, TargetNullValue=''}" Classes="body" Foreground="{DynamicResource Danger}" TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="Na bevestigen wordt meteen een PDF-preview van de bestelbon geopend."
                           Classes="body"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Content="Annuleren" MinWidth="100" Command="{Binding AnnuleerCommand}"/>
                    <Button Content="Bevestigen &amp; preview"
                            MinWidth="140"
                            Command="{Binding BevestigCommand}"
                            Background="{DynamicResource InfoBg}"
                            Foreground="{DynamicResource InfoText}"
                            FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
