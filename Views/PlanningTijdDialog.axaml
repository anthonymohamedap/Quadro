<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.PlanningTijdDialog"
        x:DataType="vm:PlanningTijdDialogViewModel"
        Title="Taak plannen"
        Width="420"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource PlanningBg}">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PlanningText}"/>
            <Setter Property="FontFamily" Value="Segoe UI, sans-serif"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background"   Value="{DynamicResource PlanningSurfaceAlt}"/>
            <Setter Property="Foreground"   Value="{DynamicResource PlanningText}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource PlanningBorder}"/>
        </Style>
    </Window.Styles>

    <Border Padding="24" Background="{DynamicResource PlanningSurface}">
        <StackPanel Spacing="16">

            <!-- Titel -->
            <StackPanel Spacing="2">
                <TextBlock Text="Taak plannen"
                           Classes="h2"
                           Foreground="{DynamicResource BrandYellow}"/>
                <TextBlock Text="Kies startdatum — taken worden automatisch verdeeld als de dag vol is."
                           Classes="label"
                           Foreground="{DynamicResource PlanningTextFaint}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Context info -->
            <Border Background="{DynamicResource PlanningSurfaceAlt}"
                    BorderBrush="{DynamicResource PlanningBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10">
                <TextBlock Text="{Binding ContextLabel}"
                           Classes="label"
                           Foreground="{DynamicResource PlanningTextMuted}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Startdatum -->
            <StackPanel Spacing="6">
                <TextBlock Text="STARTDATUM"
                           Classes="caption"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PlanningTextFaint}"
                           LetterSpacing="1.5"/>
                <DatePicker SelectedDate="{Binding GeplandeDatum}"
                            HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Geschat werk (read-only) -->
            <Border Background="{DynamicResource PlanningSurfaceAlt}"
                    BorderBrush="{DynamicResource PlanningBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Totaal geschat werk:"
                                   Classes="label"
                                   Foreground="{DynamicResource PlanningTextMuted}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DuurLabel}"
                                   Classes="h3"
                                   Foreground="{DynamicResource BrandYellow}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SpreadLabel}"
                               Classes="label"
                               Foreground="{DynamicResource PlanningTextMuted}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Knoppen -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,4,0,0">
                <Button Content="Annuleer"
                        MinWidth="100"
                        Command="{Binding AnnuleerCommand}"
                        Background="Transparent"
                        Foreground="{DynamicResource PlanningTextMuted}"
                        BorderBrush="{DynamicResource PlanningBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,8"
                        Cursor="Hand"/>
                <Button Content="Bevestig"
                        MinWidth="100"
                        Command="{Binding BevestigCommand}"
                        Background="{DynamicResource BrandYellow}"
                        Foreground="{DynamicResource PlanningBg}"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        Padding="16,8"
                        Cursor="Hand"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
