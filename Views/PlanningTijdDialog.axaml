<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.PlanningTijdDialog"
        x:DataType="vm:PlanningTijdDialogViewModel"
        Title="Taak plannen"
        Width="420"
        MinWidth="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource Surface}">

    <!-- Lichte dialoog in huisstijl (zoals KlantDialog); uitsluitend theme-tokens. -->

    <Border Padding="24" Background="{DynamicResource Surface}">
        <StackPanel Spacing="16">

            <!-- Titel -->
            <StackPanel Spacing="2">
                <TextBlock Text="Taak plannen"
                           Classes="h2"/>
                <TextBlock Text="Kies startdatum — taken worden automatisch verdeeld als de dag vol is."
                           Classes="caption"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Context info -->
            <Border Background="{DynamicResource SurfaceMutedAlt}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10">
                <TextBlock Text="{Binding ContextLabel}"
                           Classes="label"
                           Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Startdatum -->
            <StackPanel Spacing="6">
                <TextBlock Text="STARTDATUM"
                           Classes="caption"
                           FontWeight="SemiBold"/>
                <DatePicker SelectedDate="{Binding GeplandeDatum}"
                            HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Geschat werk (read-only) -->
            <Border Background="{DynamicResource SurfaceMutedAlt}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Totaal geschat werk:"
                                   Classes="label"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DuurLabel}"
                                   Classes="h3"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding SpreadLabel}"
                               Classes="label"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Knoppen -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,4,0,0">
                <Button Content="Annuleer"
                        MinWidth="100"
                        Command="{Binding AnnuleerCommand}"
                        Classes="GhostBtn"
                        Padding="16,8"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Bevestig"
                        MinWidth="100"
                        Command="{Binding BevestigCommand}"
                        Classes="AccentBtn"
                        Padding="16,8"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
