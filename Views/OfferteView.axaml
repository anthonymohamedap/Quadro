<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:QuadroApp.ViewModels"
    xmlns:m="clr-namespace:QuadroApp.Model.DB"
    xmlns:conv="clr-namespace:QuadroApp.Converters"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    x:Class="QuadroApp.Views.OfferteView"
    x:DataType="vm:OfferteViewModel">

	<Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource SurfaceMutedAlt}"
          TextElement.Foreground="{DynamicResource TextPrimary}">

		<!-- ================= HEADER ================= -->
		<controls:QuadroHeader Grid.Row="0" Title="OFFERTEBEHEER" BackCommand="{Binding GaTerugCommand}"/>

		<!-- ================= BODY ================= -->
		<ScrollViewer Grid.Row="1"
                      Margin="24"
                      VerticalScrollBarVisibility="Auto">

			<Grid ColumnDefinitions="1*,1.05*"
                  ColumnSpacing="24">

				<!-- ================= LEFT COLUMN ================= -->
				<StackPanel Grid.Column="1" Spacing="20">

					<!-- KLANT -->
					<Border Classes="quadro-card">
						<Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,Auto"
                              RowSpacing="10"
                              ColumnSpacing="10">

							<StackPanel Spacing="6">

								<!-- Huidige klant -->
								<Border Background="{DynamicResource InfoBg}"
										CornerRadius="6"
										Padding="6">

									<TextBlock FontWeight="SemiBold"
											   Foreground="{DynamicResource InfoText}"
											   TextTrimming="CharacterEllipsis"
											   ToolTip.Tip="{Binding SelectedKlant.Achternaam}"
											   Text="{Binding SelectedKlant.Achternaam,
                                  TargetNullValue='Geen klant geselecteerd'}"/>
								</Border>
								<!-- Zoek -->
								<TextBox Watermark="Zoek klant..."
										 Text="{Binding KlantZoekterm, UpdateSourceTrigger=PropertyChanged}"/>

								<!-- Selectie -->
								<ComboBox ItemsSource="{Binding GefilterdeKlanten}"
										  SelectedItem="{Binding SelectedKlant, Mode=TwoWay}"
										  MaxDropDownHeight="250">

									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:Klant">
											<TextBlock TextTrimming="CharacterEllipsis">
												<Run Text="{Binding Voornaam}" />
												<Run Text=" " />
												<Run Text="{Binding Achternaam}" />
											</TextBlock>
										</DataTemplate>
									</ComboBox.ItemTemplate>

								</ComboBox>

							</StackPanel>

							<Button Grid.Row="1"
                                    Grid.Column="1"
                                    Content="+ Nieuwe klant"
                                    Command="{Binding NieuweKlantCommand}"
                                    Classes="AccentBtn"/>
						</Grid>
					</Border>

					<!-- REGELS -->
					<Border Classes="quadro-card">
						<StackPanel Spacing="12">

							<Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                  ColumnSpacing="8">

								<TextBlock Text="Regels"
                                           Classes="h2"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>

								<Button Grid.Column="1"
                                        Content="+ Toevoegen"
                                        Command="{Binding RegelToevoegenCommand}"
                                        Classes="AccentBtn"/>

								<Button Grid.Column="2"
                                        Content="Dupliceren"
                                        Command="{Binding RegelDuplicerenCommand}"
                                        Classes="AccentBtn"/>

								<Button Grid.Column="3"
                                        Content="– Verwijderen"
                                        Command="{Binding RegelVerwijderenCommand}"
                                        CommandParameter="{Binding SelectedRegel}"
                                        Classes="AccentBtn"/>
							</Grid>

							<!-- TABEL HEADERS -->
							<Grid ColumnDefinitions="Auto,60,60,60,90,*,110"
                                  Opacity="0.6">
								<TextBlock Grid.Column="1" Text="Aantal" Classes="label" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="2" Text="Breedte" Classes="label" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="3" Text="Hoogte" Classes="label" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="4" Text="Type lijst" Classes="label" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="6"
                                           Text="Totaal"
                                           Classes="label"
                                           HorizontalAlignment="Right"/>
							</Grid>

							<Separator/>

							<ListBox ItemsSource="{Binding Regels}"
                                     SelectedItem="{Binding SelectedRegel, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0">

								<ListBox.ItemTemplate>
									<DataTemplate x:DataType="m:OfferteRegel">
										<Border Padding="6">
											<Grid ColumnDefinitions="Auto,60,60,60,90,*,110">
												<TextBlock Grid.Column="1" Text="{Binding AantalStuks}"/>
												<TextBlock Grid.Column="2"
                                                           Text="{Binding BreedteCm, StringFormat={}{0} cm}"
                                                           TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="3"
                                                           Text="{Binding HoogteCm, StringFormat={}{0} cm}"
                                                           TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="4"
                                                           Text="{Binding TypeLijst.Artikelnummer}"
                                                           ToolTip.Tip="{Binding TypeLijst.Artikelnummer}"
                                                           TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="6"
                                                           Text="{Binding TotaalInclBtw, StringFormat=€ {0:N2}}"
                                                           HorizontalAlignment="Right"
                                                           FontWeight="SemiBold"/>
											</Grid>
										</Border>
									</DataTemplate>
								</ListBox.ItemTemplate>
							</ListBox>
						</StackPanel>
					</Border>

				</StackPanel>

				<!-- ================= RIGHT COLUMN ================= -->
				<StackPanel Grid.Column="0"
                            Spacing="20">

					<!-- REGEL DETAILS -->
					<Border Classes="quadro-card">
						<Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="10"
                              ColumnSpacing="12">

							<TextBlock Text="Regel details"
                                       Grid.ColumnSpan="2"
                                       Classes="h2"
                                       TextTrimming="CharacterEllipsis"/>

							<!-- ══ TITEL — eerste invoerveld ══ -->
							<TextBlock Grid.Row="1" Grid.Column="0" Text="Titel (verschijnt op bon)" VerticalAlignment="Center" MaxWidth="220" TextWrapping="Wrap"/>
							<TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Watermark="bv. Poster A3, Trouwfoto, Canvas..."
                                     Text="{Binding SelectedRegel.Titel, Mode=TwoWay}"/>

							<TextBlock Grid.Row="2" Grid.Column="0" Text="Aantal stuks" VerticalAlignment="Center"/>
							<NumericUpDown Grid.Row="2"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Minimum="1"
                                           Maximum="999"
                                           Value="{Binding SelectedRegel.AantalStuks, Mode=TwoWay}"/>

							<TextBlock Grid.Row="3" Grid.Column="0" Text="Type lijst" VerticalAlignment="Top"/>

							<StackPanel Grid.Row="3"
                                        Grid.Column="1"
                                        Spacing="6">

								<!-- Geselecteerde lijst — zelfde stijl als klant display -->
								<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
									<Border Grid.Column="0"
                                            Background="{DynamicResource InfoBg}"
                                            CornerRadius="6"
                                            Padding="6">
										<TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InfoText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding SelectedRegelTypeLijst.Artikelnummer}"
                                                   Text="{Binding SelectedRegelTypeLijst.Artikelnummer,
                                                          TargetNullValue='Geen lijst geselecteerd'}"/>
									</Border>
									<Button Grid.Column="1"
                                                Content="&#x270F;"
                                                ToolTip.Tip="Lijst bewerken"
                                                Command="{Binding OpenTypeLijstCommand}"
                                                Width="28"
                                                Height="24"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                Background="{DynamicResource BorderSubtle}"
                                                Foreground="{DynamicResource TextPrimary}"/>
									<Button Grid.Column="2"
                                                Content="&#x1F4CB;"
                                                ToolTip.Tip="Open lijstenbeheer"
                                                Command="{Binding OpenLijstBeheerCommand}"
                                                Width="28"
                                                Height="24"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                Background="{DynamicResource BorderSubtle}"
                                                Foreground="{DynamicResource TextPrimary}"/>
								</Grid>

								<!-- Zoek + kies -->
								<TextBox Watermark="Zoek artikelnummer…"
                                         Text="{Binding TypeLijstZoekterm, UpdateSourceTrigger=PropertyChanged}"/>

								<ComboBox ItemsSource="{Binding GefilterdeTypeLijsten}"
                                          SelectedItem="{Binding SelectedRegelTypeLijst, Mode=TwoWay}"
                                          MaxDropDownHeight="300">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:TypeLijst">
											<TextBlock Text="{Binding Artikelnummer}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>

							</StackPanel>

							<TextBlock Grid.Row="4" Grid.Column="0" Text="Breedte (cm)" VerticalAlignment="Center"/>
							<NumericUpDown Grid.Row="4"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Grid.Column="1"
                                           Value="{Binding SelectedRegel.BreedteCm, Mode=TwoWay}"/>

							<TextBlock Grid.Row="5" Grid.Column="0" Text="Hoogte (cm)" VerticalAlignment="Center"/>
							<NumericUpDown Grid.Row="5"
                                           Foreground="{DynamicResource TextPrimary}"
                                           Grid.Column="1"
                                           Value="{Binding SelectedRegel.HoogteCm, Mode=TwoWay}"/>

							<TextBlock Grid.Row="6" Grid.Column="0" Text="Afgesproken prijs (incl. BTW)" VerticalAlignment="Center" MaxWidth="220" TextWrapping="Wrap"/>
							<TextBox Grid.Row="6"
                                     Grid.Column="1"
                                     Text="{Binding SelectedRegelAfgesprokenPrijs, Mode=TwoWay}"/>

							<TextBlock Grid.Row="7" Grid.Column="0" Text="Inleg (B × H) cm" VerticalAlignment="Center"/>
							<Grid Grid.Row="7"
                                  Grid.Column="1"
                                  ColumnDefinitions="*,8,*">
								<NumericUpDown Value="{Binding SelectedRegel.InlegBreedteCm, Mode=TwoWay}"
                                               Foreground="{DynamicResource TextPrimary}"/>
								<TextBlock Grid.Column="1"
                                           Text="×"
                                           HorizontalAlignment="Center"/>
								<NumericUpDown Grid.Column="2"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Value="{Binding SelectedRegel.InlegHoogteCm, Mode=TwoWay}"/>
							</Grid>
							<TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       VerticalAlignment="Top"
                                       Text="Opmerking"/>

							<TextBox Grid.Row="8"
									 Grid.Column="1"
									 AcceptsReturn="True"
									 MinHeight="70"
									 TextWrapping="Wrap"
									 Text="{Binding SelectedRegel.Opmerking, Mode=TwoWay}"/>

							<!-- AFHAAL DATUM PER REGEL — read-only: wordt bepaald via de planning (US-27) -->
							<TextBlock Grid.Row="9" Grid.Column="0" Text="Afhaal datum" VerticalAlignment="Center"/>
							<StackPanel Grid.Row="9"
										Grid.Column="1"
										Orientation="Horizontal"
										Spacing="8"
										VerticalAlignment="Center">
								<TextBlock Text="{Binding SelectedRegel.AfhaalDatum, StringFormat='{}{0:dd/MM/yyyy}', TargetNullValue='— nog niet gepland'}"
										   VerticalAlignment="Center"
										   FontWeight="SemiBold"
										   Foreground="{DynamicResource TextPrimary}"/>
								<TextBlock Text="(via planning)"
										   Classes="caption"
										   VerticalAlignment="Center"/>
							</StackPanel>
						</Grid>
					</Border>

					<!-- AFWERKINGEN -->
					<Border Classes="quadro-card">

						<Grid ColumnDefinitions="Auto,*,Auto,*"
							  RowDefinitions="Auto,Auto,Auto,Auto"
							  ColumnSpacing="16"
							  RowSpacing="12">

							<!-- Titel -->
							<StackPanel Grid.Row="0"
										Grid.ColumnSpan="4"
										Spacing="2"
										Margin="0,0,0,6">

								<TextBlock Text="Afwerkingen"
										   Classes="h2"
										   TextTrimming="CharacterEllipsis"/>

								<TextBlock Text="Glas – Passe-partout – Diepte – Opkleven – Rug"
										   Classes="caption"
										   TextTrimming="CharacterEllipsis"
										   ToolTip.Tip="Glas – Passe-partout – Diepte – Opkleven – Rug"/>
							</StackPanel>

							<!-- ================= RIJ 1 ================= -->
							<TextBlock Grid.Row="1"
									   Grid.Column="0"
									   Text="(G)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"
									   Foreground="{DynamicResource TextPrimary}"/>

							<StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
								<ComboBox ItemsSource="{Binding GlasNamen}"
										  SelectedItem="{Binding SelectedGlasNaam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Glas type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="GlasBox"
										  ItemsSource="{Binding GlasVarianten}"
										  SelectedItem="{Binding SelectedRegelGlasVariant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  IsVisible="{Binding SelectedGlasNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<TextBlock Grid.Row="1"
									   Grid.Column="2"
									   Text="(P)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"
									   Foreground="{DynamicResource TextPrimary}"/>

							<StackPanel Grid.Row="1" Grid.Column="3" Spacing="4">
								<ComboBox ItemsSource="{Binding Passe1Namen}"
										  SelectedItem="{Binding SelectedPasse1Naam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Passe-partout type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="Passe1Box"
										  ItemsSource="{Binding Passe1VariantLijst}"
										  SelectedItem="{Binding SelectedRegelPasse1Variant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  Foreground="{DynamicResource TextPrimary}"
										  IsVisible="{Binding SelectedPasse1Naam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<!-- ================= RIJ 2 ================= -->
							<TextBlock Grid.Row="2"
									   Grid.Column="0"
									   Text="(P)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"
									   Foreground="{DynamicResource TextPrimary}"/>

							<StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
								<ComboBox ItemsSource="{Binding Passe2Namen}"
										  SelectedItem="{Binding SelectedPasse2Naam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Passe-partout type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="Passe2Box"
										  ItemsSource="{Binding Passe2VariantLijst}"
										  SelectedItem="{Binding SelectedRegelPasse2Variant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  IsVisible="{Binding SelectedPasse2Naam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<TextBlock Grid.Row="2"
									   Grid.Column="2"
									   Text="(D)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"
									   Foreground="{DynamicResource TextPrimary}"/>

							<StackPanel Grid.Row="2" Grid.Column="3" Spacing="4">
								<ComboBox ItemsSource="{Binding DiepteNamen}"
										  SelectedItem="{Binding SelectedDiepteNaam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Diepte type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="DiepteBox"
										  ItemsSource="{Binding DiepteVariantLijst}"
										  SelectedItem="{Binding SelectedRegelDiepteVariant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  IsVisible="{Binding SelectedDiepteNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<!-- ================= RIJ 3 ================= -->
							<TextBlock Grid.Row="3"
									   Grid.Column="0"
									   Text="(O)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"
									   Foreground="{DynamicResource TextPrimary}"/>

							<StackPanel Grid.Row="3" Grid.Column="1" Spacing="4">
								<ComboBox ItemsSource="{Binding OpklevenNamen}"
										  SelectedItem="{Binding SelectedOpklevenNaam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Opkleven type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="OpklevenBox"
										  ItemsSource="{Binding OpklevenVariantLijst}"
										  SelectedItem="{Binding SelectedRegelOpklevenVariant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  IsVisible="{Binding SelectedOpklevenNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

							<TextBlock Grid.Row="3"
									   Grid.Column="2"
									   Text="(R)"
									   VerticalAlignment="Center"
									   FontWeight="SemiBold"
									   Opacity="0.8"/>

							<StackPanel Grid.Row="3" Grid.Column="3" Spacing="4">
								<ComboBox ItemsSource="{Binding RugNamen}"
										  SelectedItem="{Binding SelectedRugNaam, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Rug type...">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
								<ComboBox x:Name="RugBox"
										  ItemsSource="{Binding RugVariantLijst}"
										  SelectedItem="{Binding SelectedRegelRugVariant, Mode=TwoWay}"
										  HorizontalAlignment="Stretch"
										  PlaceholderText="Variant..."
										  IsVisible="{Binding SelectedRugNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsVariant">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Border Width="14" Height="14" CornerRadius="3"
												        VerticalAlignment="Center"
												        BorderBrush="{DynamicResource TextSecondary}" BorderThickness="1"
												        Background="{Binding Kleur, Converter={x:Static conv:BooleanConverters.HexToBrush}}"/>
												<TextBlock Text="{Binding Beschrijving}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
											</StackPanel>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>
							</StackPanel>

						</Grid>
					</Border>

					<!-- LEGACY -->
					<Border Classes="quadro-card">
						<Grid ColumnDefinitions="Auto,*,Auto,Auto"
                              ColumnSpacing="8">

							<TextBlock Text="Afwerking (G P P D O R)"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

							<TextBox Grid.Column="1"
                                     Text="{Binding LegacyCode, Mode=TwoWay}"/>

							<Button Grid.Column="2"
                                    Content="Toepassen"
                                    Command="{Binding ApplyLegacyCodeCommand}"/>

							<Button Grid.Column="3"
                                    Content="Genereren"
                                    Command="{Binding GenerateLegacyCodeCommand}"/>
						</Grid>
					</Border>
					<Border Classes="quadro-card">

						<StackPanel Spacing="14">

							<TextBlock Text="Prijsaanpassingen"
									   Classes="h2"
									   TextTrimming="CharacterEllipsis"/>

							<Grid ColumnDefinitions="Auto,*"
								  RowDefinitions="Auto,Auto,Auto"
								  RowSpacing="10"
								  ColumnSpacing="12">

								<!-- KORTING -->
								<TextBlock Text="Korting (%)" VerticalAlignment="Center"/>
								<NumericUpDown Grid.Row="0"
											   Grid.Column="1"
											   Minimum="0"
											   Foreground="{DynamicResource TextPrimary}"
											   Maximum="100"
											   Value="{Binding Offerte.KortingPct, Mode=TwoWay}"/>

								<!-- MEERPRIJS -->
								<TextBlock Grid.Row="1" Grid.Column="0" Text="Meerprijs (incl. BTW)" VerticalAlignment="Center"/>
								<TextBox Grid.Row="1"
										 Grid.Column="1"
										 Text="{Binding Offerte.MeerPrijsIncl, Mode=TwoWay}"/>

								<!-- VOORSCHOT -->
								<TextBlock Grid.Row="2" Grid.Column="0" Text="Voorschot betaald" VerticalAlignment="Center"/>
								<NumericUpDown Grid.Row="2"
										 Grid.Column="1"
										 Minimum="0"
										 Increment="5"
										 FormatString="'€ '0.00"
										 Watermark="Bedrag"
										 Value="{Binding VoorschotBedragInput, Mode=TwoWay}"/>

							</Grid>

						</StackPanel>

					</Border>
				</StackPanel>
			</Grid>
		</ScrollViewer>

		<!-- ================= STICKY FOOTER ================= -->
		<Border Grid.Row="2"
                Background="{DynamicResource Surface}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="16">
			<Grid ColumnDefinitions="*,Auto"
				  ColumnSpacing="30">

				<!-- LINKS ACTIES -->
				<StackPanel Spacing="6">
					<WrapPanel>

						<Button Content="Berekenen"
								Command="{Binding BerekenCommand}"
								Classes="AccentBtn"
								Margin="0,0,12,6"/>

						<Button Content="Opslaan"
								Command="{Binding SaveCommand}"
								Classes="AccentBtn"
								Margin="0,0,12,6"/>

						<Button Content="{Binding FactuurButtonText}"
								Command="{Binding FactuurCommand}"
								Background="{DynamicResource InfoBorder}"
								Foreground="{DynamicResource InfoText}"
								FontWeight="Bold"
								Margin="0,0,12,6"/>

						<!-- Bevestigen: alleen zichtbaar als er nog GEEN werkbon is -->
						<Button Content="Bevestigen → Bestelling"
								Command="{Binding BevestigenCommand}"
								IsVisible="{Binding IsBevestigenZichtbaar}"
								Classes="AccentBtn"
								Margin="0,0,12,6"/>

						<!-- Planning: zichtbaar zodra de werkbon bestaat -->
						<Button Content="📅 Planning bekijken"
								Command="{Binding OpenPlanningCommand}"
								IsVisible="{Binding IsPlanningZichtbaar}"
								Background="{DynamicResource SuccessBg}"
								Foreground="{DynamicResource Success}"
								FontWeight="Bold"
								Margin="0,0,12,6"/>
					</WrapPanel>

					<TextBlock Text="{Binding FactuurStatusText}"
							   Classes="label"
							   Foreground="{DynamicResource TextSecondary}"
							   TextTrimming="CharacterEllipsis"
							   ToolTip.Tip="{Binding FactuurStatusText}"/>
				</StackPanel>

				<!-- RECHTS PRIJZEN -->
				<Grid Grid.Column="1"
					  HorizontalAlignment="Right"
					  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
					  RowSpacing="6">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto" MinWidth="120"/>
					</Grid.ColumnDefinitions>

					<TextBlock Text="Subtotaal"/>
					<TextBlock Grid.Row="0"
							   Grid.Column="1"
							   Text="{Binding OfferteEx, StringFormat=€ {0:N2}}"
							   HorizontalAlignment="Right"/>

					<TextBlock Grid.Row="1" Grid.Column="0" Text="BTW"/>
					<TextBlock Grid.Row="1"
							   Grid.Column="1"
							   Text="{Binding OfferteBtw, StringFormat=€ {0:N2}}"
							   HorizontalAlignment="Right"/>

					<TextBlock Grid.Row="2"
							   Grid.Column="0"
							   Text="Totaal incl. BTW"
							   FontWeight="Bold"/>

					<TextBlock Grid.Row="2"
							   Grid.Column="1"
							   Text="{Binding OfferteIncl, StringFormat=€ {0:N2}}"
							   Classes="h2"
							   FontWeight="Bold"
							   HorizontalAlignment="Right"/>

					<!-- VOORSCHOT — zichtbaar zodra bedrag > 0 -->
					<TextBlock Grid.Row="3"
							   Grid.Column="0"
							   Text="Voorschot betaald"
							   Foreground="{DynamicResource Success}"
							   FontWeight="SemiBold"
							   IsVisible="{Binding HeeftVoorschot}"/>
					<TextBlock Grid.Row="3"
							   Grid.Column="1"
							   Text="{Binding OfferteVoorschot, StringFormat=- € {0:N2}}"
							   Foreground="{DynamicResource Success}"
							   FontWeight="Bold"
							   HorizontalAlignment="Right"
							   IsVisible="{Binding HeeftVoorschot}"/>

					<TextBlock Grid.Row="4"
							   Grid.Column="0"
							   Text="Rest te betalen"
							   Foreground="{DynamicResource Danger}"
							   FontWeight="SemiBold"/>

					<TextBlock Grid.Row="4"
							   Grid.Column="1"
							   Text="{Binding OfferteRest, StringFormat=€ {0:N2}}"
							   Foreground="{DynamicResource Danger}"
							   FontWeight="Bold"
							   HorizontalAlignment="Right"/>

				</Grid>

			</Grid>
		</Border>

	</Grid>
</UserControl>
