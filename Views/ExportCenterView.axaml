<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
             xmlns:vm="using:QuadroApp.ViewModels"
             xmlns:sm="using:QuadroApp.Service.Model"
             x:Class="QuadroApp.Views.ExportCenterView"
             x:DataType="vm:ExportCenterViewModel"
             Background="{DynamicResource SurfaceMuted}">

    <Grid RowDefinitions="Auto,*">
        <controls:QuadroHeader Title="EXPORTCENTER" BackCommand="{Binding GaTerugCommand}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Configureerbare Excel-export"
                               Classes="h1"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Kies een dataset, pas velden en relaties aan, of start vanuit een Nederlandstalige preset."
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Exportmap" Classes="h3" TextTrimming="CharacterEllipsis"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     MinWidth="160"
                                     Text="{Binding ExportFolder}"
                                     IsReadOnly="True"
                                     Watermark="Selecteer een map"/>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button Content="📁 Kies map"
                                        Command="{Binding ChooseExportFolderCommand}"
                                        Classes="MainBtn"
                                        Margin="0,0,8,6"/>
                                <Button Content="✔️ Alles selecteren"
                                        Command="{Binding SelecteerAlleVeldenCommand}"
                                        Classes="MainBtn"
                                        Margin="0,0,8,6"/>
                                <Button Content="🧹 Wis selectie"
                                        Command="{Binding WisVeldenCommand}"
                                        Classes="MainBtn"
                                        Margin="0,0,0,6"/>
                            </WrapPanel>
                        </Grid>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding LastExportPath, StringFormat='Laatste bestand: {0}'}"
                                   IsVisible="{Binding HasLastExportPath}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>
                        <WrapPanel>
                            <Button Content="📂 Open exportmap"
                                    Command="{Binding OpenExportFolderCommand}"
                                    Classes="MainBtn"
                                    Margin="0,0,8,6"/>
                            <Button Content="🗎 Open laatste bestand"
                                    Command="{Binding OpenLastExportCommand}"
                                    Classes="MainBtn"
                                    Margin="0,0,0,6"
                                    IsVisible="{Binding HasLastExportPath}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Exportinstellingen" Classes="h3" TextTrimming="CharacterEllipsis"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Dataset" Classes="label" Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox ItemsSource="{Binding BeschikbareDatasets}"
                                          HorizontalAlignment="Stretch"
                                          SelectedItem="{Binding SelectedDataset, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="sm:ExportDatasetOptie">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Naam}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Beschrijving}" Classes="caption" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Standaardpreset" Classes="label" Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox ItemsSource="{Binding BeschikbarePresets}"
                                          HorizontalAlignment="Stretch"
                                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="sm:ExportPresetOptie">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Naam}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Beschrijving}" Classes="caption" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="10" Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding DatasetBeschrijving}" FontWeight="SemiBold" Foreground="{DynamicResource TextHeading}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding GeselecteerdePresetBeschrijving}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding GeselecteerdeEntiteitenTekst}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding GeselecteerdeVeldenTekst}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding GeselecteerdeRelatiesTekst}" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Button Content="📤 Exporteer huidige selectie"
                                Command="{Binding ExporteerConfiguratieCommand}"
                                Classes="MainBtn"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Specifieke records (optioneel)" Classes="h2" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Laat alles leeg om de volledige dataset te exporteren, of kies hier specifieke records samen met hun relaties."
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"/>

                        <WrapPanel>
                            <Button Content="✔️ Selecteer alle records"
                                    Command="{Binding SelecteerAlleEntiteitenCommand}"
                                    Classes="MainBtn"
                                    Margin="0,0,8,6"/>
                            <Button Content="🧹 Wis recordfilter"
                                    Command="{Binding WisEntiteitenCommand}"
                                    Classes="MainBtn"
                                    Margin="0,0,0,6"/>
                        </WrapPanel>

                        <TextBox Watermark="🔍 Zoek op naam of omschrijving..."
                                 Text="{Binding EntiteitZoekterm, Mode=TwoWay}"
                                 Margin="0,4,0,0"/>

                        <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Geen records beschikbaar voor deze dataset."
                                           IsVisible="{Binding GeenEntiteiten}"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap"/>

                                <ItemsControl ItemsSource="{Binding GepagineerdeEntiteiten}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="sm:ExportEntiteitOptie">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,4">
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsGeselecteerd, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Beschrijving}" Classes="caption" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Id}" Classes="caption" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0" IsVisible="{Binding HeeftEntiteiten}">
                                    <Button Grid.Column="0"
                                            Content="◀ Vorige"
                                            Command="{Binding VorigePaginaCommand}"
                                            Classes="MainBtn"
                                            IsEnabled="{Binding KanNaarVorigePagina}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PaginaInfo}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="2"
                                            Content="Volgende ▶"
                                            Command="{Binding VolgendePaginaCommand}"
                                            Classes="MainBtn"
                                            IsEnabled="{Binding KanNaarVolgendePagina}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <Border Grid.Column="0" MinWidth="280" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Hoofdvelden" Classes="h2" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Vink de velden aan die je op het hoofdwerkblad wil opnemen." Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>

                            <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="8" Padding="10">
                                <ItemsControl ItemsSource="{Binding BeschikbareKolommen}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="sm:ExportKolomOptie">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,4">
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsGeselecteerd, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Groep}" Classes="caption" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" MinWidth="280" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Relaties" Classes="h2" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Kies extra werkbladen voor logische relaties, zoals leverancier → lijsten of klant → offertes." Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>

                            <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="8" Padding="10">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Geen relaties beschikbaar voor deze dataset."
                                               IsVisible="{Binding GeenRelaties}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap"/>

                                    <ItemsControl ItemsSource="{Binding BeschikbareRelaties}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="sm:ExportRelatieOptie">
                                                <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,4,0,0">
                                                    <StackPanel Spacing="8">
                                                        <CheckBox IsChecked="{Binding IsGeselecteerd, Mode=TwoWay}">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Beschrijving}" Classes="caption" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </CheckBox>

                                                        <ItemsControl ItemsSource="{Binding Kolommen}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="sm:ExportKolomOptie">
                                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="18,0,0,0">
                                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsGeselecteerd, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                                        <TextBlock Grid.Column="2" Text="{Binding Groep}" Classes="caption" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
