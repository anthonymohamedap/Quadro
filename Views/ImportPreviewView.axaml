<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuadroApp.ViewModels"
        xmlns:imp="clr-namespace:QuadroApp.Model.Import"
        xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
        x:Class="QuadroApp.Views.ImportPreviewView"
        x:DataType="vm:ImportPreviewViewModel"
        Width="1200" Height="760"
        MinWidth="900" MinHeight="560"
        CanResize="True"
        Background="{DynamicResource SurfaceMuted}"
        Title="Importvoorbeeld">

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- HEADER (gedeelde Quadro-taal) -->
    <controls:QuadroHeader Grid.Row="0"
                           Title="{Binding EntityName, StringFormat='IMPORT · {0}'}"
                           ShowBackButton="False"/>

    <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" ColumnDefinitions="2.2*,1*" Margin="16">

      <!-- TOOLBAR -->
      <Grid Grid.Row="0" Grid.ColumnSpan="2"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8"
            Margin="0,0,0,12">
        <TextBox Grid.Column="0" MinWidth="220"
                 Watermark="Kies Excel-bestand..."
                 Text="{Binding SelectedFilePath, Mode=TwoWay}"/>
        <Button Grid.Column="1" Content="Bestand kiezen" Classes="AccentBtn" Padding="12,6"
                Command="{Binding ChooseFileCommand}"/>
        <Button Grid.Column="2" Content="Voorbeeld laden" Classes="AccentBtn" Padding="12,6"
                Command="{Binding DryRunCommand}"/>
        <Button Grid.Column="3" Content="Import uitvoeren" Classes="AccentBtn" Padding="12,6"
                Command="{Binding CommitImportCommand}"/>
        <Button Grid.Column="4" Content="Lopende actie stoppen" Classes="GhostBtn"
                Command="{Binding CancelOperationCommand}" IsEnabled="{Binding IsBusy}"/>
      </Grid>

      <!-- LINKS: overzicht + rijen -->
      <Border Grid.Row="1" Grid.Column="0" Classes="Card" Margin="0,0,12,0" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="10">

            <TextBlock Text="Overzicht" Classes="h2"/>

            <TextBlock Text="{Binding SummaryText}" Classes="body" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding WarningText}" Classes="body" TextWrapping="Wrap"
                       Foreground="{DynamicResource Warning}"
                       IsVisible="{Binding HasWarnings}"/>

            <TextBlock Text="{Binding ProgressText}" Classes="body" TextWrapping="Wrap"
                       FontStyle="Italic" Foreground="{DynamicResource TextSecondary}"/>

            <ListBox ItemsSource="{Binding Rows}"
                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PreviewRowItem">
                  <Border BorderBrush="{DynamicResource BorderSubtle}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="8"
                          Margin="0,0,0,8"
                          Background="{DynamicResource Surface}">

                    <StackPanel Spacing="4">

                      <DockPanel>
                        <Border DockPanel.Dock="Right"
                                Padding="6,2"
                                CornerRadius="5"
                                Background="{DynamicResource WarningBg}">
                          <TextBlock Text="{Binding StateLabel}" Classes="caption"
                                     FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding Title}"/>
                      </DockPanel>

                      <ItemsControl ItemsSource="{Binding Values}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                              <TextBlock Text="{Binding Key, StringFormat={}{0}: }"
                                         FontWeight="SemiBold"/>
                              <TextBlock Text="{Binding Value}" TextWrapping="Wrap"/>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- RECHTS: details geselecteerde rij -->
      <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10">
          <Border Classes="Card" Padding="12">
            <StackPanel>
              <TextBlock Text="Rijproblemen" Classes="h3" Margin="0,0,0,8"/>
              <ListBox ItemsSource="{Binding SelectedRowIssues}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="imp:ImportRowIssue">
                    <Border Padding="6" Margin="0,0,0,6" CornerRadius="6"
                            Background="{DynamicResource SurfaceMutedAlt}">
                      <StackPanel>
                        <TextBlock Text="{Binding Severity}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ColumnName}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding ColumnName}"/>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>

          <Border Classes="Card" Padding="12">
            <StackPanel>
              <TextBlock Text="Waarden van geselecteerde rij" Classes="h3" Margin="0,0,0,8"
                         TextWrapping="Wrap"/>
              <ItemsControl ItemsSource="{Binding SelectedRowValues}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                      <TextBlock Text="{Binding Key, StringFormat={}{0}: }"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Value}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ONDERBALK -->
      <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
        <Button Content="Annuleren" Classes="GhostBtn" Command="{Binding CancelCommand}"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
