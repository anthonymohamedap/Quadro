<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QuadroApp.Views.Controls.QuadroHeader"
             x:Name="Root"
             x:CompileBindings="False">

    <!-- Herbruikbare Quadro-header: donkere balk met links het logo + QUADRO +
         de view-titel, en rechts (verticaal gecentreerd) een optionele Terug-knop.
         Typografie hier lokaal als style-classes (wordmark heeft geen theme-equivalent). -->
    <UserControl.Styles>
        <Style Selector="TextBlock.brandTitle">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnDark}"/>
        </Style>
        <Style Selector="TextBlock.brandSub">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedOnDark}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource BrandDark}" Height="70">
        <DockPanel Margin="20,0" LastChildFill="True">

            <Button DockPanel.Dock="Right"
                    Content="⬅ Terug"
                    Command="{Binding BackCommand, ElementName=Root}"
                    IsVisible="{Binding ShowBackButton, ElementName=Root}"
                    VerticalAlignment="Center"
                    Classes="AccentBtn"
                    CornerRadius="8"
                    Padding="12,6"/>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Spacing="12">

                <Ellipse Width="35" Height="35" Fill="{DynamicResource BrandYellow}"/>

                <TextBlock Text="QUADRO"
                           Classes="brandTitle"
                           VerticalAlignment="Center"/>

                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Classes="brandSub"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Title, ElementName=Root}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
