<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:snap="using:QuadroApp.Model.Snapshot"
    xmlns:conv="using:QuadroApp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    x:Class="QuadroApp.Views.ArchiefView"
    x:DataType="vm:ArchiefViewModel"
    Background="{DynamicResource SurfaceMuted}">

    <UserControl.Resources>
        <conv:JaarConverter x:Key="JaarConv"/>
    </UserControl.Resources>

    <!-- Root grid: lijst + overlay detail-venster -->
    <Grid>

        <!-- ══════════════════ HOOFD-LAYOUT ══════════════════ -->
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- HEADER -->
            <controls:QuadroHeader Grid.Row="0" Title="ARCHIEF" BackCommand="{Binding GaTerugCommand}"/>

            <!-- FILTER-BALK -->
            <Border Grid.Row="1" Background="{DynamicResource Surface}" Padding="16,10"
                    BoxShadow="{StaticResource ShadowBar}">
                <WrapPanel>
                    <TextBox Watermark="Zoek op klant, offerte-nr, reden…"
                             MinWidth="220"
                             Margin="0,0,12,4"
                             Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox ItemsSource="{Binding BeschikbareJaren}"
                              SelectedItem="{Binding GeselecteerdJaar, Mode=TwoWay}"
                              MinWidth="110"
                              Margin="0,0,12,4"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource JaarConv}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{Binding ArchiefItems.Count, StringFormat='{}{0} entries'}"
                               VerticalAlignment="Center"
                               Classes="caption"/>
                </WrapPanel>
            </Border>

            <!-- LIJST -->
            <Grid Grid.Row="2">
                <!-- Spinner -->
                <Border IsVisible="{Binding IsBezig}"
                        Background="{DynamicResource OverlayLight}"
                        ZIndex="10">
                    <TextBlock Text="Laden…"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Classes="h2" Foreground="{DynamicResource TextSecondary}"/>
                </Border>

                <!-- Leeg -->
                <TextBlock IsVisible="{Binding !ArchiefItems.Count}"
                           Text="Geen gearchiveerde offertes gevonden."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Classes="h3" Foreground="{DynamicResource TextSecondary}"/>

                <ListBox ItemsSource="{Binding ArchiefItems}"
                         SelectedItem="{Binding GeselecteerdItem, Mode=TwoWay}"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="12,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:OfferteArchief">
                            <Border Background="{DynamicResource Surface}"
                                    CornerRadius="8"
                                    Margin="0,4"
                                    Padding="16,12"
                                    BoxShadow="{StaticResource ShadowCard}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="4">

                                        <!-- Klant + datum -->
                                        <WrapPanel>
                                            <TextBlock Text="{Binding KlantNaam}"
                                                       Classes="h3"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding KlantNaam}"
                                                       Margin="0,0,10,0"/>
                                            <TextBlock Text="—" Foreground="{DynamicResource TextSecondary}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding OfferteDatum, StringFormat='{}{0:dd/MM/yyyy}'}"
                                                       Classes="body" Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,0,10,0"/>
                                            <!-- Hersteld badge -->
                                            <Border IsVisible="{Binding IsHersteld}"
                                                    Background="{DynamicResource SuccessBg}"
                                                    CornerRadius="4"
                                                    Padding="6,2">
                                                <TextBlock Text="✓ Hersteld"
                                                           Classes="caption"
                                                           Foreground="{DynamicResource Success}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </WrapPanel>

                                        <!-- IDs + status -->
                                        <WrapPanel>
                                            <TextBlock Classes="caption" Margin="0,0,14,0">
                                                <Run Text="Offerte #"/>
                                                <Run Text="{Binding OrigineleOfferteId}"/>
                                            </TextBlock>
                                            <TextBlock Classes="caption" Margin="0,0,14,0"
                                                       IsVisible="{Binding HadWerkBon}">
                                                <Run Text="+ Werkbon"/>
                                            </TextBlock>
                                            <TextBlock Classes="caption"
                                                       Text="{Binding StatusOpMoment}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </WrapPanel>

                                        <!-- Reden (indien aanwezig) -->
                                        <TextBlock Text="{Binding Reden}"
                                                   IsVisible="{Binding Reden, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                   Classes="caption"
                                                   Foreground="{DynamicResource Danger}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Classes="caption">
                                            <Run Text="Gearchiveerd: "/>
                                            <Run Text="{Binding GearchiveerdOp, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Prijs rechts -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TotaalInclBtw, StringFormat='€ {0:N2}'}"
                                               Classes="h3"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- STATUS-BALK -->
            <Border Grid.Row="3" Background="{DynamicResource SurfaceHeader}" Padding="16,6">
                <TextBlock Classes="caption">
                    <Run Text="{Binding ArchiefItems.Count}"/>
                    <Run Text=" gearchiveerde offertes"/>
                </TextBlock>
            </Border>
        </Grid>

        <!-- ══════════════════ DETAIL OVERLAY ══════════════════ -->
        <!-- Donkere achtergrond -->
        <Border IsVisible="{Binding IsDetailOpen}"
                Background="{DynamicResource OverlayDim}"
                ZIndex="50"/>

        <!-- Detail-paneel (schuift in van rechts) -->
        <Border IsVisible="{Binding IsDetailOpen}"
                ZIndex="51"
                HorizontalAlignment="Right"
                Width="480"
                Background="{DynamicResource Surface}"
                BoxShadow="{StaticResource ShadowPanel}">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Detail header -->
                <Border Grid.Row="0" Background="{DynamicResource BrandDark}" Padding="20,14">
                    <DockPanel>
                        <Button Content="✕ Sluiten"
                                Command="{Binding SluitDetailCommand}"
                                DockPanel.Dock="Right"
                                Background="Transparent"
                                Foreground="{DynamicResource TextOnDark}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource TextMutedOnDark}"
                                CornerRadius="4"
                                Padding="10,4"/>
                        <TextBlock Text="Archief detail"
                                   Classes="h3"
                                   Foreground="{DynamicResource TextOnDark}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Border>

                <!-- Scrollbare inhoud -->
                <ScrollViewer Grid.Row="1" Padding="20">
                    <StackPanel Spacing="16">

                        <!-- Klant blok -->
                        <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="KLANT" Classes="caption" FontWeight="Bold"/>
                                <TextBlock Text="{Binding GeselecteerdItem.KlantNaam}"
                                           Classes="h3"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding GeselecteerdItem.KlantNaam}"/>
                                <TextBlock Text="{Binding GeselecteerdSnapshot.Klant.Email}"
                                           Classes="caption"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding GeselecteerdSnapshot.Klant.Email}"
                                           IsVisible="{Binding GeselecteerdSnapshot.Klant.Email,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="{Binding GeselecteerdSnapshot.Klant.Telefoon}"
                                           Classes="caption"
                                           IsVisible="{Binding GeselecteerdSnapshot.Klant.Telefoon,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Classes="caption" TextWrapping="Wrap">
                                    <Run Text="{Binding GeselecteerdSnapshot.Klant.Straat}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding GeselecteerdSnapshot.Klant.Nummer}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding GeselecteerdSnapshot.Klant.Postcode}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding GeselecteerdSnapshot.Klant.Gemeente}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Offerte info -->
                        <Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Text="OFFERTE" Classes="caption" FontWeight="Bold"/>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="2">
                                    <TextBlock Grid.Row="0" Grid.Column="0" MinWidth="100" Text="Offerte #" Classes="caption"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GeselecteerdItem.OrigineleOfferteId}" Classes="caption" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" Classes="caption"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GeselecteerdItem.StatusOpMoment}" Classes="caption" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Datum:" Classes="caption"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding GeselecteerdItem.OfferteDatum, StringFormat='{}{0:dd/MM/yyyy}'}"
                                               Classes="caption" Foreground="{DynamicResource TextPrimary}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Totaal incl:" Classes="caption"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding GeselecteerdItem.TotaalInclBtw, StringFormat='€ {0:N2}'}"
                                               Classes="caption" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Had werkbon:" Classes="caption"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding GeselecteerdItem.HadWerkBon}"
                                               Classes="caption" Foreground="{DynamicResource TextPrimary}"/>
                                </Grid>
                                <TextBlock Text="{Binding GeselecteerdSnapshot.Offerte.Opmerking}"
                                           IsVisible="{Binding GeselecteerdSnapshot.Offerte.Opmerking,
                                               Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Classes="caption"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Offerteregels -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding GeselecteerdSnapshot,
                                        Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock Text="OFFERTEREGELS" Classes="caption" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding GeselecteerdSnapshot.Regels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="snap:SnapshotOfferteRegel">
                                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="5"
                                                Padding="12,8" Margin="0,2">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Classes="body" FontWeight="SemiBold" TextWrapping="Wrap">
                                                        <Run Text="{Binding AantalStuks}"/>
                                                        <Run Text="×  "/>
                                                        <Run Text="{Binding Titel}"/>
                                                    </TextBlock>
                                                    <TextBlock Classes="caption" TextWrapping="Wrap">
                                                        <Run Text="{Binding BreedteCm, StringFormat='{}{0:N1}'}"/>
                                                        <Run Text=" × "/>
                                                        <Run Text="{Binding HoogteCm, StringFormat='{}{0:N1}'}"/>
                                                        <Run Text=" cm"/>
                                                        <Run Text="  |  "/>
                                                        <Run Text="{Binding TypeLijstNaam}"/>
                                                    </TextBlock>
                                                    <!-- Afwerkingen -->
                                                    <WrapPanel>
                                                        <TextBlock IsVisible="{Binding GlasNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                   Classes="caption" Foreground="{DynamicResource StatPurpleText}" Margin="0,0,8,0">
                                                            <Run Text="Glas: "/><Run Text="{Binding GlasNaam}"/>
                                                        </TextBlock>
                                                        <TextBlock IsVisible="{Binding PassePartout1Naam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                   Classes="caption" Foreground="{DynamicResource StatPurpleText}" Margin="0,0,8,0">
                                                            <Run Text="PP1: "/><Run Text="{Binding PassePartout1Naam}"/>
                                                        </TextBlock>
                                                        <TextBlock IsVisible="{Binding PassePartout2Naam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                   Classes="caption" Foreground="{DynamicResource StatPurpleText}" Margin="0,0,8,0">
                                                            <Run Text="PP2: "/><Run Text="{Binding PassePartout2Naam}"/>
                                                        </TextBlock>
                                                        <TextBlock IsVisible="{Binding RugNaam, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                   Classes="caption" Foreground="{DynamicResource StatPurpleText}">
                                                            <Run Text="Rug: "/><Run Text="{Binding RugNaam}"/>
                                                        </TextBlock>
                                                    </WrapPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TotaalInclBtw, StringFormat='€ {0:N2}'}"
                                                           Classes="body" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Werkbon taken -->
                        <StackPanel Spacing="6"
                                    IsVisible="{Binding GeselecteerdSnapshot.Taken.Count}">
                            <TextBlock Text="WERKTAKEN" Classes="caption" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding GeselecteerdSnapshot.Taken}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="snap:SnapshotWerkTaak">
                                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="5"
                                                Padding="12,8" Margin="0,2">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Omschrijving}"
                                                           Classes="body" FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Classes="caption">
                                                    <Run Text="{Binding GeplandVan, StringFormat='{}{0:dd/MM HH:mm}'}"/>
                                                    <Run Text=" – "/>
                                                    <Run Text="{Binding GeplandTot, StringFormat='{}{0:HH:mm}'}"/>
                                                    <Run Text="  ("/>
                                                    <Run Text="{Binding DuurMinuten}"/>
                                                    <Run Text=" min)"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Resource}"
                                                           IsVisible="{Binding Resource, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                           Classes="caption"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Actie-knoppen onderaan -->
                <Border Grid.Row="2" Padding="20,14" Background="{DynamicResource SurfaceMutedAlt}"
                        BoxShadow="{StaticResource ShadowTopEdge}">
                    <StackPanel Spacing="8">
                        <!-- Niet hersteld: herstel-knop tonen -->
                        <Button Content="Herstel als nieuwe offerte (Concept)"
                                Command="{Binding HerstellenCommand}"
                                CommandParameter="{Binding GeselecteerdItem}"
                                IsVisible="{Binding !GeselecteerdItem.IsHersteld}"
                                Background="{DynamicResource StatBlueText}"
                                Foreground="{DynamicResource TextOnDark}"
                                CornerRadius="6"
                                Padding="16,10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                FontWeight="SemiBold"/>

                        <!-- Al hersteld: info tonen -->
                        <Border IsVisible="{Binding GeselecteerdItem.IsHersteld}"
                                Background="{DynamicResource SuccessBg}" CornerRadius="6" Padding="12,8">
                            <TextBlock Foreground="{DynamicResource Success}" FontWeight="SemiBold" TextWrapping="Wrap">
                                <Run Text="Hersteld naar offerte #"/>
                                <Run Text="{Binding GeselecteerdItem.HersteldNaarOfferteId}"/>
                            </TextBlock>
                        </Border>

                        <!-- Permanent verwijderen (altijd zichtbaar in detail) -->
                        <Button Content="Permanent verwijderen"
                                Command="{Binding VerwijderenCommand}"
                                CommandParameter="{Binding GeselecteerdItem}"
                                Background="{DynamicResource Danger}"
                                Foreground="{DynamicResource TextOnDark}"
                                CornerRadius="6"
                                Padding="16,8"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
