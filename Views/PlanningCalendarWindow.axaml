<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="QuadroApp.Views.PlanningCalendarWindow"
    x:CompileBindings="False"
    MinWidth="1100"
    MinHeight="700"
    WindowState="Maximized"
    WindowStartupLocation="CenterOwner"
    Title="WerkBon Planning"
    Background="{DynamicResource SurfaceMuted}">

	<!-- Huisstijl: uitsluitend theme-tokens (QuadroTheme.axaml); geen hex,
	     geen lokale brushes. Dagtegel-status → kleur gebeurt hier via
	     Classes.*-bindingen op booleans uit DayTile (geen IBrush in de VM). -->
	<Window.Styles>

		<!-- Dagtegels -->
		<Style Selector="Border.DayTile">
			<Setter Property="Background"  Value="{DynamicResource Surface}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>
		<Style Selector="Border.DayTile.weekend">
			<Setter Property="Background" Value="{DynamicResource SurfaceMutedAlt}"/>
		</Style>
		<Style Selector="Border.DayTile.otherMonth">
			<Setter Property="Opacity" Value="0.55"/>
		</Style>
		<Style Selector="Border.DayTile.today">
			<Setter Property="Background"  Value="{DynamicResource InfoBg}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource InfoBorder}"/>
		</Style>
		<Style Selector="Border.DayTile.blocked">
			<Setter Property="Background"  Value="{DynamicResource DangerBg}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource Danger}"/>
		</Style>
		<Style Selector="Border.DayTile.selected">
			<Setter Property="BorderBrush" Value="{DynamicResource BrandYellow}"/>
		</Style>
		<Style Selector="Border.DayTile:pointerover">
			<Setter Property="BorderBrush" Value="{DynamicResource BrandYellow}"/>
		</Style>

		<!-- Capaciteitsbalk: proportioneel (0..1), kleur per niveau -->
		<Style Selector="ProgressBar.Capacity">
			<Setter Property="Minimum"  Value="0"/>
			<Setter Property="Maximum"  Value="1"/>
			<Setter Property="Height"   Value="4"/>
			<Setter Property="MinWidth" Value="0"/>
			<Setter Property="CornerRadius" Value="2"/>
			<Setter Property="Background" Value="{DynamicResource BorderSubtle}"/>
		</Style>
		<Style Selector="ProgressBar.capLow">
			<Setter Property="Foreground" Value="{DynamicResource CapacityLow}"/>
		</Style>
		<Style Selector="ProgressBar.capMid">
			<Setter Property="Foreground" Value="{DynamicResource CapacityMid}"/>
		</Style>
		<Style Selector="ProgressBar.capHigh">
			<Setter Property="Foreground" Value="{DynamicResource CapacityHigh}"/>
		</Style>
		<Style Selector="ProgressBar.capFull">
			<Setter Property="Foreground" Value="{DynamicResource CapacityFull}"/>
		</Style>

		<!-- Vlakke lijsten (maandgrid, weektabel, regels): geen item-chrome -->
		<Style Selector="ListBox">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding"         Value="0"/>
		</Style>
		<Style Selector="ListBoxItem">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Padding"    Value="0"/>
			<Setter Property="Margin"     Value="0"/>
		</Style>
		<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>

		<Style Selector="Rectangle.Divider">
			<Setter Property="Height" Value="1"/>
			<Setter Property="Fill"   Value="{DynamicResource BorderSubtle}"/>
			<Setter Property="Margin" Value="0,4"/>
		</Style>
	</Window.Styles>

	<!-- ROOT: Panel wraps Grid + Toast overlay -->
	<Panel>
		<Grid RowDefinitions="70,Auto,*">

			<!-- ══════════════ HEADER (zelfde taal als QuadroHeader) ══════════════ -->
			<Border Grid.Row="0" Background="{DynamicResource BrandDark}">
				<DockPanel Margin="20,0" LastChildFill="False">
					<StackPanel DockPanel.Dock="Left"
								Orientation="Horizontal"
								VerticalAlignment="Center"
								Spacing="12">
						<Ellipse Width="35" Height="35" Fill="{DynamicResource BrandYellow}"/>
						<TextBlock Text="QUADRO"
								   Classes="h2"
								   Foreground="{DynamicResource TextOnDark}"
								   VerticalAlignment="Center"/>
						<TextBlock Text="PLANNING"
								   Classes="body"
								   Foreground="{DynamicResource TextMutedOnDark}"
								   VerticalAlignment="Center"/>
					</StackPanel>

					<Button DockPanel.Dock="Right"
							Content="⬅ Sluiten"
							Classes="AccentBtn"
							VerticalAlignment="Center"
							Padding="12,6"
							Click="SluitButton_Click"/>
				</DockPanel>
			</Border>

			<!-- ══════════════ TOOLBAR: maandnavigatie ══════════════ -->
			<Border Grid.Row="1"
					Background="{DynamicResource Surface}"
					BorderBrush="{DynamicResource BorderSubtle}"
					BorderThickness="0,0,0,1">
				<StackPanel Orientation="Horizontal"
							Spacing="8"
							Margin="20,10"
							VerticalAlignment="Center">
					<Button Content="←" Command="{Binding PrevMonthCommand}" Classes="MainBtn"/>
					<TextBlock Text="{Binding MonthTitle}"
							   Classes="h3"
							   MinWidth="150"
							   TextAlignment="Center"
							   VerticalAlignment="Center"/>
					<Button Content="→" Command="{Binding NextMonthCommand}" Classes="MainBtn"/>
					<Button Content="Vandaag"
							Command="{Binding TodayCommand}"
							Classes="GhostBtn"
							Margin="8,0,0,0"/>
				</StackPanel>
			</Border>

			<!-- ══════════════ BODY: 2-column ══════════════ -->
			<Grid Grid.Row="2" ColumnDefinitions="*,Auto">

				<!-- LEFT — Calendar grid -->
				<Grid Grid.Column="0"
					  RowDefinitions="Auto,*"
					  Margin="16,16,16,8">

					<!-- Weekday headers -->
					<ItemsControl Grid.Row="0" ItemsSource="{Binding WeekHeaders}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="7"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding}"
										   HorizontalAlignment="Center"
										   Classes="caption"
										   FontWeight="SemiBold"
										   Margin="0,0,0,8"
										   TextTrimming="CharacterEllipsis"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<!-- Month day grid -->
					<ListBox Grid.Row="1" ItemsSource="{Binding MonthDays}">
						<ListBox.ItemsPanel>
							<ItemsPanelTemplate>
								<UniformGrid Columns="7"/>
							</ItemsPanelTemplate>
						</ListBox.ItemsPanel>
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border Classes="DayTile"
										Classes.weekend="{Binding IsWeekend}"
										Classes.otherMonth="{Binding IsOtherMonth}"
										Classes.today="{Binding IsToday}"
										Classes.blocked="{Binding IsGeblokkeerd}"
										Classes.selected="{Binding IsSelected}"
										Margin="3"
										Padding="10,8"
										MinHeight="80"
										Cursor="Hand"
										PointerPressed="DayTile_PointerPressed">

									<StackPanel Spacing="4">
										<!-- Day number (+ blok-indicator) -->
										<StackPanel Orientation="Horizontal" Spacing="4">
											<TextBlock Text="🚫"
													   Classes="caption"
													   IsVisible="{Binding IsGeblokkeerd}"
													   VerticalAlignment="Center"/>
											<TextBlock Text="{Binding DayNumber}"
													   Classes="body"
													   FontWeight="Bold"/>
										</StackPanel>

										<!-- Capacity bar (proportioneel — schaalt mee met de tegel) -->
										<ProgressBar Classes="Capacity"
													 Classes.capLow="{Binding CapLow}"
													 Classes.capMid="{Binding CapMid}"
													 Classes.capHigh="{Binding CapHigh}"
													 Classes.capFull="{Binding CapFull}"
													 Value="{Binding Busy}"/>

										<!-- Hours / blocked label -->
										<TextBlock Text="{Binding BusyLabel}"
												   Classes="caption"
												   TextTrimming="CharacterEllipsis"
												   ToolTip.Tip="{Binding BusyLabel}"/>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</Grid>

				<!-- RIGHT PANEL -->
				<Border Grid.Column="1"
						MinWidth="380"
						MaxWidth="460"
						Background="{DynamicResource Surface}"
						BorderBrush="{DynamicResource BorderSubtle}"
						BorderThickness="1,0,0,0"
						Padding="20,16">
					<ScrollViewer HorizontalScrollBarVisibility="Disabled"
								  VerticalScrollBarVisibility="Auto">
						<StackPanel Spacing="0">

							<!-- ══ DAG DETAILS ══ -->
							<StackPanel Spacing="2" Margin="0,0,0,12">
								<TextBlock Text="DAG DETAILS" Classes="caption" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding SelectedDateLang}"
										   Classes="h3"
										   Margin="0,4,0,0"
										   TextTrimming="CharacterEllipsis"
										   ToolTip.Tip="{Binding SelectedDateLang}"/>
							</StackPanel>

							<!-- Geblokkeerd indicator -->
							<Border IsVisible="{Binding IsGeselecteerdeDagGeblokkeerd}"
									Background="{DynamicResource DangerBg}"
									BorderBrush="{DynamicResource Danger}"
									BorderThickness="1"
									CornerRadius="8"
									Padding="14,10"
									Margin="0,0,0,12">
								<StackPanel Spacing="4">
									<StackPanel Orientation="Horizontal" Spacing="10">
										<TextBlock Text="🚫" Classes="h3" VerticalAlignment="Center"/>
										<TextBlock Text="Deze dag is geblokkeerd — er kunnen geen taken worden ingepland."
												   Classes="label"
												   Foreground="{DynamicResource Danger}"
												   TextWrapping="Wrap"
												   VerticalAlignment="Center"/>
									</StackPanel>
									<TextBlock Text="{Binding GeselecteerdeDagRedenTekst}"
											   IsVisible="{Binding GeselecteerdeDagRedenTekst, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
											   Classes="caption"
											   Foreground="{DynamicResource Danger}"
											   FontStyle="Italic"
											   Margin="30,0,0,0"
											   TextWrapping="Wrap"/>
								</StackPanel>
							</Border>

							<!-- Tasks for selected day -->
							<ItemsControl ItemsSource="{Binding TakenVanDag}"
										  Margin="0,0,0,4">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Border Background="{DynamicResource SurfaceMutedAlt}"
												BorderBrush="{DynamicResource BorderSubtle}"
												BorderThickness="1"
												Padding="12,10"
												Margin="0,0,0,8"
												CornerRadius="8"
												Cursor="Hand">

											<Border.ContextMenu>
												<ContextMenu>
													<MenuItem Header="✏ Herplannen"
															  Click="OnHerplanMenuClick"/>
													<MenuItem Header="🗑 Verwijderen"
															  Click="OnVerwijderMenuClick"/>
												</ContextMenu>
											</Border.ContextMenu>

											<Grid ColumnDefinitions="*,Auto">
												<StackPanel Spacing="3">
													<TextBlock Text="{Binding WerkBon.Id, StringFormat='WerkBon #{0}'}"
															   Classes="body"
															   FontWeight="Bold"/>
													<TextBlock Text="{Binding WerkBon.Offerte.Klant.Achternaam}"
															   Classes="label"
															   Foreground="{DynamicResource TextSecondary}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding WerkBon.Offerte.Klant.Achternaam}"/>
													<TextBlock Text="{Binding Omschrijving}"
															   Classes="label"
															   Foreground="{DynamicResource TextSecondary}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding Omschrijving}"/>
												</StackPanel>
												<Border Grid.Column="1"
														Background="{DynamicResource SurfaceHeader}"
														CornerRadius="20"
														Padding="8,3"
														VerticalAlignment="Top">
													<TextBlock Text="{Binding DuurMinuten, StringFormat='{}{0} min'}"
															   Classes="caption"/>
												</Border>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<!-- Empty day state -->
							<Border IsVisible="{Binding !TakenVanDag.Count}"
									Padding="0,8,0,8">
								<TextBlock Text="Geen taken gepland voor deze dag."
										   Classes="caption"
										   HorizontalAlignment="Center"/>
							</Border>

							<Rectangle Classes="Divider" Margin="0,4,0,14"/>

							<!-- ══ PLAN REGELS (contextueel) ══ -->

							<!-- No-werkbon hint -->
							<Border IsVisible="{Binding GeenWerkBon}"
									Background="{DynamicResource InfoBg}"
									BorderBrush="{DynamicResource InfoBorder}"
									BorderThickness="1"
									CornerRadius="8"
									Padding="14,12"
									Margin="0,0,0,16">
								<StackPanel Orientation="Horizontal" Spacing="10">
									<TextBlock Text="📋" Classes="h3" VerticalAlignment="Center"/>
									<TextBlock Text="Open planning vanuit een werkbon om regels te kunnen plannen."
											   Classes="label"
											   Foreground="{DynamicResource InfoText}"
											   TextWrapping="Wrap"
											   VerticalAlignment="Center"/>
								</StackPanel>
							</Border>

							<!-- Werkbon regels panel -->
							<StackPanel IsVisible="{Binding HeeftWerkBon}"
										Spacing="10"
										Margin="0,0,0,16">
								<TextBlock Text="WERKBON REGELS" Classes="caption" FontWeight="SemiBold"/>

								<ListBox ItemsSource="{Binding RegelsVanWerkBon}"
										 Background="{DynamicResource SurfaceMutedAlt}"
										 CornerRadius="8"
										 Padding="8">
									<ListBox.ItemTemplate>
										<DataTemplate>
											<Border Padding="6,5"
													Margin="0,2"
													CornerRadius="6"
													Cursor="Hand">
												<StackPanel Orientation="Horizontal" Spacing="10">
													<CheckBox IsChecked="{Binding IsSelected}"
															  VerticalAlignment="Center"/>
													<TextBlock Text="{Binding Label}"
															   Classes="label"
															   TextWrapping="Wrap"
															   VerticalAlignment="Center"/>
												</StackPanel>
											</Border>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>

								<Button Content="Plan geselecteerde regels"
										Command="{Binding PlanGeselecteerdeRegelsCommand}"
										Classes="AccentBtn"
										Padding="12,8"
										HorizontalAlignment="Stretch"
										HorizontalContentAlignment="Center"/>

								<!-- US-21: aparte datum per inlijsting -->
								<Button Content="Plan per regel (aparte datums)"
										Command="{Binding PlanPerRegelCommand}"
										Classes="GhostBtn"
										HorizontalAlignment="Stretch"
										HorizontalContentAlignment="Center"/>
							</StackPanel>

							<Rectangle Classes="Divider" Margin="0,0,0,14"/>

							<!-- ══ WEEKDETAIL ══ -->
							<StackPanel Spacing="10">
								<DockPanel>
									<TextBlock Text="WEEKDETAIL" Classes="caption" FontWeight="SemiBold" VerticalAlignment="Center"/>
									<Button DockPanel.Dock="Right"
											Content="🖨 Weeklijst"
											Command="{Binding OpenWeekWerkLijstCommand}"
											Classes="GhostBtn"/>
								</DockPanel>

								<Border Background="{DynamicResource SurfaceMutedAlt}"
										BorderBrush="{DynamicResource BorderSubtle}"
										BorderThickness="1"
										CornerRadius="8"
										Padding="12,10">
									<StackPanel Spacing="8">

										<!-- Row count badge -->
										<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
											<Border Background="{DynamicResource InfoBg}"
													BorderBrush="{DynamicResource InfoBorder}"
													BorderThickness="1"
													CornerRadius="20"
													Padding="10,3">
												<TextBlock Text="{Binding WeekRows.Count, StringFormat='{}{0} regels'}"
														   Classes="caption"
														   FontWeight="SemiBold"
														   Foreground="{DynamicResource InfoText}"/>
											</Border>
										</StackPanel>

										<!-- Empty state -->
										<Border IsVisible="{Binding !WeekRows.Count}"
												Padding="0,16"
												HorizontalAlignment="Center">
											<StackPanel Spacing="6" HorizontalAlignment="Center">
												<TextBlock Text="📋"
														   Classes="h2"
														   HorizontalAlignment="Center"/>
												<TextBlock Text="Geen regels voor deze week"
														   Classes="caption"
														   HorizontalAlignment="Center"/>
											</StackPanel>
										</Border>

										<!-- Week table -->
										<StackPanel IsVisible="{Binding WeekRows.Count}" Spacing="4">

											<!-- Column headers -->
											<Grid ColumnDefinitions="48,1.2*,1.2*,*,*,48" ColumnSpacing="4" Margin="0,0,0,4">
												<TextBlock Text="Bon"      Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="1" Text="Klant"    Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="2" Text="Afmeting" Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="3" Text="Lijst"    Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="4" Text="Dag"      Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="5" Text="Duur"     Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
											</Grid>

											<Rectangle Classes="Divider"/>

											<!-- Data rows -->
											<ListBox ItemsSource="{Binding WeekRows}" MaxHeight="300">
												<ListBox.ItemTemplate>
													<DataTemplate>
														<Border Background="{DynamicResource Surface}"
																BorderBrush="{DynamicResource BorderSubtle}"
																BorderThickness="1"
																CornerRadius="6"
																Padding="6,7"
																Margin="0,2">
															<Grid ColumnDefinitions="48,1.2*,1.2*,*,*,48" ColumnSpacing="4">
																<TextBlock Text="{Binding BonNr}"     Classes="label" TextTrimming="CharacterEllipsis"/>
																<TextBlock Grid.Column="1" Text="{Binding KlantNaam}" Classes="label" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding KlantNaam}"/>
																<TextBlock Grid.Column="2" Text="{Binding Afmeting}"  Classes="label" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Afmeting}"/>
																<TextBlock Grid.Column="3" Text="{Binding Lijst}"     Classes="label" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Lijst}"/>
																<TextBlock Grid.Column="4" Text="{Binding Dag}"       Classes="caption" TextTrimming="CharacterEllipsis"/>
																<TextBlock Grid.Column="5" Text="{Binding DuurMin, StringFormat='{}{0}m'}" Classes="label" TextTrimming="CharacterEllipsis"/>
															</Grid>
														</Border>
													</DataTemplate>
												</ListBox.ItemTemplate>
											</ListBox>
										</StackPanel>

									</StackPanel>
								</Border>
							</StackPanel>

							<Rectangle Classes="Divider" Margin="0,14,0,14"/>

							<!-- ══ DAG/WEEK BLOKKEREN (uitzonderingsactie, onderaan) ══ -->
							<StackPanel Spacing="6" Margin="0,0,0,8">
								<TextBlock Text="BLOKKEREN" Classes="caption" FontWeight="SemiBold"/>
								<TextBox Watermark="Reden (optioneel)..."
										 Text="{Binding BlokkeerReden, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
										 IsVisible="{Binding !IsGeselecteerdeDagGeblokkeerd}"/>
								<WrapPanel>
									<Button Content="{Binding BlokkeerDagButtonText}"
											Command="{Binding ToggleBlokkeerDagCommand}"
											Classes="DangerBtn"
											Margin="0,0,8,6"/>
									<Button Content="🔒 Blokkeer/deblokkeer week"
											Command="{Binding ToggleBlokkeerWeekCommand}"
											Classes="DangerBtn"
											Margin="0,0,0,6"/>
								</WrapPanel>
							</StackPanel>

						</StackPanel>
					</ScrollViewer>
				</Border>
			</Grid>

		</Grid>

		<!-- ══════════════ TOAST OVERLAY (bovenaan, zoals WeekWerkLijst) ══════════════ -->
		<ItemsControl ItemsSource="{Binding ToastMessages}"
					  HorizontalAlignment="Center"
					  VerticalAlignment="Top"
					  Margin="0,84,0,0"
					  IsHitTestVisible="False">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Spacing="8"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Border Padding="14,10"
							CornerRadius="8"
							Background="{Binding BackgroundBrush}"
							BorderBrush="{DynamicResource BrandDark}"
							BorderThickness="1"
							MinWidth="220"
							MaxWidth="340">
						<TextBlock Text="{Binding Message}"
								   Classes="body"
								   Foreground="{DynamicResource TextOnDark}"
								   FontWeight="SemiBold"
								   TextWrapping="Wrap"/>
					</Border>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</Panel>

</Window>
