<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="clr-namespace:QuadroApp.Model.DB"
    x:Class="QuadroApp.Views.AfwerkingenView"
    x:DataType="vm:AfwerkingenViewModel"
    Background="{DynamicResource SurfaceMuted}">

    <UserControl.Resources>
        <!-- Subtle chip style for variant rows -->
        <ControlTheme x:Key="ChipTextBox" TargetType="TextBox">
            <Setter Property="Background"     Value="{DynamicResource Surface}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="6,4"/>
        </ControlTheme>
    </UserControl.Resources>

	<Grid RowDefinitions="Auto,*,Auto">

		<!-- ░░ HEADER ░░ -->
		<controls:QuadroHeader Title="LIJSTENBEHEER" BackCommand="{Binding GaTerugCommand}"/>

		<!-- ░░ MAIN CONTENT ░░ -->
		<ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
			<StackPanel Margin="24" Spacing="16">

				<TextBlock Text="🧩 Afwerkingen" Classes="h1" TextTrimming="CharacterEllipsis"/>

				<!-- Toolbar: wrapt op smalle vensters -->
				<WrapPanel Margin="0,0,0,8">
					<Button Content="🔄 Verversen"  Command="{Binding RefreshAsyncCommand}" Classes="MainBtn" Margin="0,0,8,6"/>
					<Button Content="➕ Nieuw"       Command="{Binding NewAsyncCommand}"      Classes="MainBtn" Margin="0,0,8,6"/>
					<Button Content="💾 Opslaan"     Command="{Binding SaveAsyncCommand}"     Classes="MainBtn" Margin="0,0,8,6"/>
					<Button Content="🗑️ Verwijderen" Command="{Binding DeleteAsyncCommand}"   Classes="MainBtn" Margin="0,0,8,6"/>
					<Button Content="📥 Excel-import" Command="{Binding ImportExcelCommand}"  Classes="MainBtn" Margin="0,0,0,6"/>
				</WrapPanel>

				<!-- Twee kolommen: star-gesized met minimumbreedte -->
				<Grid ColumnDefinitions="1*,1.8*" ColumnSpacing="14">

					<!-- ═══════════ LINKERKOLOM ═══════════ -->
					<Border Classes="card" MinWidth="300" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
						<StackPanel Spacing="14">

							<StackPanel Spacing="8">
								<TextBlock Text="Groep" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>

								<ComboBox ItemsSource="{Binding Groepen}"
										  SelectedItem="{Binding SelectedGroep}"
										  MinWidth="140">
									<ComboBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsGroep">
											<TextBlock TextTrimming="CharacterEllipsis">
												<Run Text="{Binding Code}"/>
												<Run Text=" - "/>
												<Run Text="{Binding Naam}"/>
											</TextBlock>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>

								<TextBlock Text="Zoek optie" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
								<TextBox Watermark="Zoek op code of naam…"
										 Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
										 Margin="0,0,0,2"/>

								<TextBlock Text="{Binding AantalOptiesText}" Classes="label" Foreground="{DynamicResource TextSecondary}" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
							</StackPanel>

							<!-- Lijst -->
							<Border Background="{DynamicResource SurfaceMutedAlt}" CornerRadius="10" Padding="8" Margin="0,4,0,0">
								<ListBox ItemsSource="{Binding FilteredOpties}"
										 SelectedItem="{Binding SelectedOptie, Mode=TwoWay}"
										 ScrollViewer.VerticalScrollBarVisibility="Auto"
										 BorderThickness="0"
										 Background="Transparent">

									<ListBox.Styles>
										<Style Selector="ListBoxItem">
											<Setter Property="CornerRadius" Value="8"/>
											<Setter Property="Margin" Value="0,4"/>
											<Setter Property="Padding" Value="10"/>
											<Setter Property="MinHeight" Value="44"/>
											<Setter Property="Background" Value="{DynamicResource Surface}"/>
											<Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
											<Setter Property="BorderThickness" Value="1"/>
											<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
										</Style>
										<Style Selector="ListBoxItem:pointerover">
											<Setter Property="Background" Value="{DynamicResource SurfaceMutedAlt}"/>
											<Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}"/>
										</Style>
										<Style Selector="ListBoxItem:selected">
											<Setter Property="Background" Value="{DynamicResource InfoBg}"/>
											<Setter Property="BorderBrush" Value="{DynamicResource InfoBorder}"/>
										</Style>
									</ListBox.Styles>

									<ListBox.ItemTemplate>
										<DataTemplate x:DataType="m:AfwerkingsOptie">
											<Grid ColumnDefinitions="Auto,*,Auto"
												  ColumnSpacing="12"
												  VerticalAlignment="Center"
												  HorizontalAlignment="Stretch">

												<Border Background="{DynamicResource BorderSubtle}" CornerRadius="6" Padding="6,3" VerticalAlignment="Center">
													<TextBlock Text="{Binding Volgnummer, StringFormat='{}{0}'}" FontWeight="SemiBold" Foreground="{DynamicResource TextHeading}"/>
												</Border>

												<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
													<TextBlock Text="{Binding Naam}"
															   FontWeight="SemiBold"
															   Foreground="{DynamicResource TextHeading}"
															   TextWrapping="NoWrap"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding Naam}"/>
													<TextBlock Text="{Binding Varianten.Count, StringFormat='Varianten: {0}'}"
															   Classes="caption"
															   TextWrapping="NoWrap"
															   TextTrimming="CharacterEllipsis"/>
												</StackPanel>

												<!-- Leverancier code null-safe -->
												<Border Grid.Column="2" Background="{DynamicResource SurfaceHeader}" CornerRadius="6" Padding="6,3" VerticalAlignment="Center">
													<TextBlock Foreground="{DynamicResource TextPrimary}"
															   Classes="label"
															   FontWeight="SemiBold">
														<TextBlock.Text>
															<MultiBinding StringFormat="{}{0}">
																<Binding Path="Leverancier.Naam" TargetNullValue="—"/>
															</MultiBinding>
														</TextBlock.Text>
													</TextBlock>
												</Border>
											</Grid>
										</DataTemplate>
									</ListBox.ItemTemplate>
								</ListBox>
							</Border>

							<TextBlock Text="{Binding Status}" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
							<TextBlock Text="{Binding Foutmelding}" Foreground="{DynamicResource Danger}" FontWeight="Bold" TextWrapping="Wrap"/>
						</StackPanel>
					</Border>

					<!-- ═══════════ RECHTERKOLOM (details) ═══════════ -->
					<Border Grid.Column="1" Classes="card" MinWidth="360" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" CornerRadius="12" Padding="16">
						<ScrollViewer VerticalScrollBarVisibility="Auto">
							<StackPanel Spacing="20">

								<!-- Info als niets gekozen -->
								<StackPanel Spacing="8" IsVisible="{Binding HeeftGeenSelectie}">
									<TextBlock Text="Selecteer een afwerkingsoptie links om de details te bekijken."
											   Foreground="{DynamicResource TextSecondary}"
											   TextWrapping="Wrap"/>
								</StackPanel>

								<!-- Details -->
								<StackPanel Spacing="16"
											IsEnabled="{Binding HeeftSelectie}"
											IsVisible="{Binding HeeftSelectie}">

									<!-- Basis -->
									<StackPanel>
										<TextBlock Text="Basis" Classes="h2" Margin="0,6,0,10"/>

										<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10">

											<TextBlock Grid.Row="0" Grid.Column="0" MinWidth="140" Text="Naam" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<TextBox Grid.Row="0" Grid.Column="1"
													 Text="{Binding SelectedOptie.Naam, Mode=TwoWay, TargetNullValue='', FallbackValue=''}"/>

											<TextBlock Grid.Row="1"
													   Grid.Column="0"
													   Text="Familie"
													   Classes="label"
													   Foreground="{DynamicResource TextSecondary}"
													   Margin="0,6,0,4"/>

											<TextBox Grid.Row="1"
													 Grid.Column="1"
													 MaxLength="1"
													 Text="{Binding VolgnummerText, Mode=TwoWay}"
													 HorizontalContentAlignment="Center"
													 FontWeight="SemiBold"/>

											<TextBlock Grid.Row="2" Grid.Column="0" Text="Leverancier" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>

											<!-- ComboBox: ItemsSource blijft stabiel door VM-fix (Clear/Add),
                           plus Text is apart gebonden op LeverancierZoekterm -->
											<StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">

												<!-- Huidige leverancier duidelijk zichtbaar -->
												<Border Background="{DynamicResource InfoBg}"
														CornerRadius="6"
														Padding="6">

													<TextBlock FontWeight="SemiBold"
															   Foreground="{DynamicResource InfoText}"
															   Text="{Binding SelectedLeverancier.Naam, TargetNullValue='Geen leverancier geselecteerd'}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip.Tip="{Binding SelectedLeverancier.Naam}"/>
												</Border>

												<!-- Zoekbox -->
												<TextBox Watermark="Zoek leverancier..."
														 Text="{Binding LeverancierZoekterm, UpdateSourceTrigger=PropertyChanged}"/>

												<!-- Selectie -->
												<ComboBox ItemsSource="{Binding GefilterdeLeveranciers}"
														  SelectedItem="{Binding SelectedLeverancier, Mode=TwoWay}"
														  MaxDropDownHeight="250">

													<ComboBox.ItemTemplate>
														<DataTemplate x:DataType="m:Leverancier">
															<TextBlock TextTrimming="CharacterEllipsis">
																<Run Text="{Binding Naam}" />
															</TextBlock>
														</DataTemplate>
													</ComboBox.ItemTemplate>

												</ComboBox>

											</StackPanel>

											<TextBlock Grid.Row="3" Grid.Column="0" Text="Dealeroptie" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<ToggleSwitch Grid.Row="3" Grid.Column="1"
														  IsChecked="{Binding IsDealerOptie}"
														  IsEnabled="False"/>
										</Grid>
									</StackPanel>

									<Separator/>

										<!-- ═══ Varianten ═══ -->
										<StackPanel Spacing="10">

											<Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
												<TextBlock Grid.Column="0"
														   Text="Varianten"
														   Classes="h2"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis"
														   Margin="0,6,0,6"/>
												<Button Grid.Column="1"
														Content="➕ Variant toevoegen"
														Command="{Binding AddVariantCommand}"
														Classes="MainBtn"
														VerticalAlignment="Center"/>
											</Grid>

											<!-- Column headers -->
											<Grid ColumnDefinitions="*,70,80,100,40" ColumnSpacing="8" Margin="0,0,0,2">
												<TextBlock Grid.Column="0" Text="Beschrijving"  Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="1" Text="Kleur hex"     Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="2" Text="Code"          Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
												<TextBlock Grid.Column="3" Text="Std / Actief"  Classes="caption" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
											</Grid>

											<!-- Empty-state message -->
											<TextBlock Text="Geen varianten. Klik '➕ Variant toevoegen' om te beginnen."
													   Classes="caption"
													   FontStyle="Italic"
													   TextWrapping="Wrap"
													   Margin="0,4,0,0"
													   IsVisible="{Binding HeeftGeenVarianten}"/>

											<!-- Variant rows -->
											<ItemsControl ItemsSource="{Binding OptieVarianten}">
												<ItemsControl.ItemTemplate>
													<DataTemplate x:DataType="vm:AfwerkingsVariantViewModel">
														<Border Background="{DynamicResource SurfaceMutedAlt}"
																BorderBrush="{DynamicResource BorderSubtle}"
																BorderThickness="1"
																CornerRadius="8"
																Padding="10,8"
																Margin="0,0,0,6">
															<Grid ColumnDefinitions="*,70,80,100,40" ColumnSpacing="8" VerticalAlignment="Center">

																<!-- Beschrijving -->
																<TextBox Grid.Column="0"
																		 Watermark="Bijv. Zwart, Brons…"
																		 Text="{Binding Beschrijving, Mode=TwoWay}"
																		 Padding="6,4"/>

																<!-- Hex kleurcode -->
																<TextBox Grid.Column="1"
																		 Watermark="#hex"
																		 Text="{Binding Kleur, Mode=TwoWay}"
																		 Padding="6,4"/>

																<!-- Variant code -->
																<TextBox Grid.Column="2"
																		 Watermark="Code (bv. ZW)"
																		 Text="{Binding VariantCode, Mode=TwoWay}"
																		 Padding="6,4"/>

																<!-- Standaard + Actief -->
																<StackPanel Grid.Column="3"
																				Orientation="Horizontal"
																				Spacing="6"
																				VerticalAlignment="Center">
																	<CheckBox IsChecked="{Binding IsStandaard, Mode=TwoWay}"
																			  Content="⭐"
																			  ToolTip.Tip="Standaard variant — automatisch geselecteerd bij nieuwe regels"/>
																	<ToggleSwitch IsChecked="{Binding IsActief, Mode=TwoWay}"
																				  OnContent=""
																				  OffContent=""
																				  ToolTip.Tip="Actief/Inactief"/>
																</StackPanel>

																<!-- Verwijderen -->
																<Button Grid.Column="4"
																		Content="🗑️"
																		Command="{Binding DeleteCommand}"
																		Background="{DynamicResource DangerBg}"
																		Foreground="{DynamicResource StatRedText}"
																		Padding="8,4"
																		CornerRadius="6"
																		ToolTip.Tip="Variant verwijderen"/>
															</Grid>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>

										</StackPanel>

										<Separator/>

									<!-- Prijs & werk -->
									<StackPanel>
										<TextBlock Text="Prijs &amp; werk" Classes="h2" Margin="0,6,0,10"/>

										<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10">

											<TextBlock Grid.Row="0" Grid.Column="0" MinWidth="140" Text="Kostprijs per m² (€)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="0" Grid.Column="1"
														   Value="{Binding SelectedOptie.KostprijsPerM2, Mode=TwoWay, TargetNullValue=0, FallbackValue=0}"
														   Increment="0.5" FormatString="0.00"/>

											<TextBlock Grid.Row="1" Grid.Column="0" Text="Winstmarge (factor)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="1" Grid.Column="1"
														   Value="{Binding SelectedOptie.WinstMarge, Mode=TwoWay, TargetNullValue=0, FallbackValue=0}"
														   Increment="0.05" FormatString="0.000"/>

											<TextBlock Grid.Row="2" Grid.Column="0" Text="Afval (%)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="2" Grid.Column="1"
														   Value="{Binding SelectedOptie.AfvalPercentage, Mode=TwoWay, TargetNullValue=0, FallbackValue=0}"
														   Increment="0.5" FormatString="0.00"/>

											<TextBlock Grid.Row="3" Grid.Column="0" Text="Vaste kost (€)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="3" Grid.Column="1"
														   Value="{Binding SelectedOptie.VasteKost, Mode=TwoWay, TargetNullValue=0, FallbackValue=0}"
														   Increment="0.5" FormatString="0.00"/>

											<TextBlock Grid.Row="4" Grid.Column="0" Text="Werkminuten" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="4" Grid.Column="1"
														   Value="{Binding SelectedOptie.WerkMinuten, Mode=TwoWay, TargetNullValue=0, FallbackValue=0}"
														   Increment="5" Minimum="0" Maximum="1440"/>
										</Grid>
									</StackPanel>

									<Separator/>

									<!-- Preview -->
									<StackPanel>
										<TextBlock Text="Prijsberekening (voorbeeld)" Classes="h2" Margin="0,6,0,10"/>

										<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="10">
											<TextBlock Grid.Row="0" Grid.Column="0" MinWidth="140" Text="Breedte (cm)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="0" Grid.Column="1"
														   Value="{Binding PreviewBreedteCm, Mode=TwoWay, TargetNullValue=30, FallbackValue=30}"
														   Minimum="1" Maximum="300" Increment="1" FormatString="0"/>

											<TextBlock Grid.Row="1" Grid.Column="0" Text="Hoogte (cm)" Classes="label" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,4"/>
											<NumericUpDown Grid.Row="1" Grid.Column="1"
														   Value="{Binding PreviewHoogteCm, Mode=TwoWay, TargetNullValue=40, FallbackValue=40}"
														   Minimum="1" Maximum="300" Increment="1" FormatString="0"/>

											<TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
													   FontWeight="SemiBold"
													   Foreground="{DynamicResource Success}"
													   Text="{Binding PreviewPrijsText}"
													   TextWrapping="Wrap"/>
										</Grid>
									</StackPanel>

								</StackPanel>
							</StackPanel>
						</ScrollViewer>
					</Border>
				</Grid>
			</StackPanel>
		</ScrollViewer>

		<!-- ░░ FOOTER ░░ -->
		<Border Grid.Row="2" Background="{DynamicResource SurfaceMuted}" Padding="10">
			<TextBlock Text="{Binding FilteredOpties.Count, StringFormat='Aantal opties: {0}'}"
					   HorizontalAlignment="Center"
					   Classes="caption"/>
		</Border>

	</Grid>


</UserControl>
