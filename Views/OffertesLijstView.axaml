<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:QuadroApp.Views.Controls"
    xmlns:vm="using:QuadroApp.ViewModels"
    xmlns:m="using:QuadroApp.Model.DB"
    xmlns:conv="using:QuadroApp.Converters"
    x:Class="QuadroApp.Views.OffertesLijstView"
    x:DataType="vm:OffertesLijstViewModel"
    Background="{DynamicResource SurfaceMuted}">

    <UserControl.Resources>
        <conv:JaarConverter x:Key="JaarConv"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">

        <controls:QuadroHeader Title="OFFERTES" BackCommand="{Binding GaTerugCommand}"/>

        <!-- Star-rij zodat de lijst de resthoogte vult en zelf scrolt -->
        <Grid Grid.Row="1" Margin="24" RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">

            <TextBlock Text="Offertes" Classes="h1" TextTrimming="CharacterEllipsis"/>

            <!-- Toolbar: wrapt op smalle vensters -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                <TextBox MinWidth="200"
                         Watermark="Zoek offerte..."
                         Text="{Binding Zoekterm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Jaar-filter -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding BeschikbareJaren}"
                          SelectedItem="{Binding GeselecteerdJaar, Mode=TwoWay}"
                          MinWidth="100"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource JaarConv}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="&#x21BB; Vernieuwen"
                            Command="{Binding LoadCommand}"
                            CornerRadius="6"
                            Padding="10,5"
                            Margin="0,0,8,6"/>
                    <Button Content="+ Nieuw"
                            Command="{Binding NewCommand}"
                            Classes="MainBtn"
                            Margin="0,0,8,6"/>
                    <Button Content="Naar archief"
                            Command="{Binding DeleteCommand}"
                            Background="{DynamicResource StatPurpleText}"
                            Foreground="{DynamicResource TextOnDark}"
                            CornerRadius="6"
                            Padding="10,5"
                            FontWeight="SemiBold"
                            Margin="0,0,8,6"/>
                    <Button Content="Archief bekijken"
                            Command="{Binding OpenArchiefCommand}"
                            Background="{DynamicResource BrandDark}"
                            Foreground="{DynamicResource TextOnDark}"
                            CornerRadius="6"
                            Padding="10,5"
                            FontWeight="SemiBold"
                            Margin="0,0,0,6"/>
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="2"
                  ColumnDefinitions="0.7*,2*,1.1*,1.1*,1.1*,0.9*,1.1*,1.2*,Auto"
                  ColumnSpacing="8"
                  Margin="16,0,16,0">
                <TextBlock Text="Nr."          Grid.Column="0" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Klant"        Grid.Column="1" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Datum"        Grid.Column="2" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Gepland"      Grid.Column="3" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Deadline"     Grid.Column="4" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Tijd (min)"   Grid.Column="5" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Status"       Grid.Column="6" Classes="label" Foreground="{DynamicResource TextHeading}" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Totaal incl." Grid.Column="7" Classes="label" Foreground="{DynamicResource TextHeading}" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Background="{DynamicResource Surface}">

                <ListBox x:Name="OffertesList"
                         ItemsSource="{Binding FilteredOffertes}"
                         SelectedItem="{Binding SelectedOfferte, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         DoubleTapped="OffertesList_DoubleTapped">

                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Offerte">
                            <Grid ColumnDefinitions="0.7*,2*,1.1*,1.1*,1.1*,0.9*,1.1*,1.2*,Auto"
                                  VerticalAlignment="Center"
                                  ColumnSpacing="8">

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id}"
                                           Classes="h3"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Classes="h3"
                                               TextTrimming="CharacterEllipsis">
                                        <ToolTip.Tip>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                        <Binding Path="Klant.Voornaam"/>
                                                        <Binding Path="Klant.Achternaam"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </ToolTip.Tip>
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Klant.Voornaam"/>
                                                <Binding Path="Klant.Achternaam"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Classes="body"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Klant.Email}"
                                               Text="{Binding Klant.Email}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Datum, StringFormat='{}{0:dd/MM/yyyy}'}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding GeplandeDatum, StringFormat='{}{0:dd/MM}'}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="4"
                                           Text="{Binding DeadlineDatum, StringFormat='{}{0:dd/MM}'}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="5"
                                           Text="{Binding GeschatteMinuten}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="6"
                                           Text="{Binding Status}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding Status}"/>

                                <TextBlock Grid.Column="7"
                                           Text="{Binding TotaalInclBtw, StringFormat='€ {0:0.00}'}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           TextTrimming="CharacterEllipsis"/>

                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="4"
                       Text="{Binding FilteredOffertes.Count, StringFormat='Aantal offertes: {0}'}"
                       HorizontalAlignment="Center"
                       Classes="caption"/>
        </Grid>

    </Grid>

</UserControl>
