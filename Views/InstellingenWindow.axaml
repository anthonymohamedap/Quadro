<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.InstellingenWindow"
        x:DataType="vm:InstellingenViewModel"
        Width="780"
        Height="560"
        MinWidth="600"
        MinHeight="460"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Instellingen"
        Background="{DynamicResource SurfaceMuted}">

    <Grid RowDefinitions="Auto,*">
        <Border Background="{DynamicResource BrandDark}" MinHeight="70">
            <DockPanel Margin="20,0">
                <Button Content="Sluiten"
                        Click="Close_Click"
                        DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        MinWidth="100"
                        Classes="AccentBtn"
                        Padding="10,5"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Ellipse Width="35" Height="35" Fill="{DynamicResource BrandYellow}"/>
                    <TextBlock Text="QUADRO" Classes="h2" Foreground="{DynamicResource TextOnDark}" VerticalAlignment="Center"/>
                    <TextBlock Text="INSTELLINGEN" Classes="body" Foreground="{DynamicResource TextMutedOnDark}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="16">
                <Border Classes="Card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Prijsinstellingen (globale standaard)" Classes="h2"/>

                        <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Uurloon (€)" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="Uurloon (€)"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Uurloon, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Standaard prijs per meter (€)" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="Standaard prijs per meter (€)"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DefaultPrijsPerMeter, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Standaard winstfactor" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="Standaard winstfactor"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DefaultWinstFactor, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Standaard afvalpercentage (%)" Classes="label" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip.Tip="Standaard afvalpercentage (%)"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DefaultAfvalPercentage, Mode=TwoWay}"/>
                        </Grid>

                        <TextBlock Text="Tip: per lijst kan je een eigen prijs per meter, winstfactor en afvalpercentage instellen via 'Lijst bewerken'. Gebruik de standaardwaarde als fallback."
                                   Classes="caption" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Account & beveiliging -->
                <Border Classes="Card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Account &amp; beveiliging" Classes="h2"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Wachtwoord wijzigen"
                                    Classes="GhostBtn"
                                    Click="WachtwoordWijzigen_Click"/>
                            <Button x:Name="GebruikersBeheerKnop"
                                    Content="Gebruikersbeheer"
                                    Classes="GhostBtn"
                                    Click="GebruikersBeheer_Click"/>
                        </StackPanel>
                        <TextBlock Text="Gebruikersbeheer is alleen beschikbaar voor beheerders."
                                   Classes="caption" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Content="Opslaan"
                            MinWidth="110"
                            Command="{Binding SaveCommand}"
                            Classes="MainBtn"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
