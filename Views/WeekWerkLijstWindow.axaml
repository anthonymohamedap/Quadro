<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QuadroApp.ViewModels"
        x:Class="QuadroApp.Views.WeekWerkLijstWindow"
        x:DataType="vm:WeekWerkLijstViewModel"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Weeklijst"
        Background="{DynamicResource SurfaceMuted}">

	<Panel>
	<Grid RowDefinitions="Auto,*">

		<!-- HEADER -->
		<Border Grid.Row="0" Background="{DynamicResource BrandDark}" MinHeight="70">
			<DockPanel LastChildFill="False" Margin="20,0">
				<StackPanel DockPanel.Dock="Left"
							Orientation="Horizontal"
							VerticalAlignment="Center"
							Spacing="10">
					<Ellipse Width="35" Height="35" Fill="{DynamicResource BrandYellow}"/>
					<TextBlock Text="QUADRO"
							   Classes="h2"
							   Foreground="{DynamicResource TextOnDark}"
							   VerticalAlignment="Center"/>
					<TextBlock Text="{Binding Title}"
							   Classes="body"
							   Foreground="{DynamicResource TextMutedOnDark}"
							   Margin="5,0,0,0"
							   VerticalAlignment="Center"
							   TextTrimming="CharacterEllipsis"
							   ToolTip.Tip="{Binding Title}"/>
				</StackPanel>

				<StackPanel DockPanel.Dock="Right"
							Orientation="Horizontal"
							Spacing="10"
							VerticalAlignment="Center">
					<TextBlock Text="{Binding Year}" Classes="body" Foreground="{DynamicResource TextOnDark}" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding WeekNr, StringFormat='Week {0}'}" Classes="body" Foreground="{DynamicResource TextOnDark}" VerticalAlignment="Center"/>

					<Button Content="🔄 Vernieuwen"
							Command="{Binding VerversCommand}"
							VerticalAlignment="Center"
							Background="{DynamicResource IconBlue}"
							Foreground="{DynamicResource TextOnDark}"
							FontWeight="Bold"
							CornerRadius="8"
							Padding="10,5"
							MinHeight="32"/>

					<Button Content="🖨 PDF afdrukken"
							Command="{Binding PrintPdfCommand}"
							VerticalAlignment="Center"
							Background="{DynamicResource Success}"
							Foreground="{DynamicResource TextOnDark}"
							FontWeight="Bold"
							CornerRadius="8"
							Padding="10,5"
							MinHeight="32"/>

				</StackPanel>
			</DockPanel>
		</Border>

		<!-- CONTENT -->
		<Grid Grid.Row="1" Margin="20">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel Spacing="14">

					<TextBlock Text="🖨 Weeklijst (print overzicht)"
							   Classes="h1"/>

					<!-- Blocks per klant -->
					<ItemsControl ItemsSource="{Binding Blocks}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<StackPanel Spacing="8">

									<!-- Klantnaam -->
									<Border BorderBrush="{DynamicResource BrandYellow}" BorderThickness="0 0 3 0" Margin="0,10,0,0">
										<TextBlock Text="{Binding KlantNaam}"
												   Classes="h2"
												   TextTrimming="CharacterEllipsis"
												   ToolTip.Tip="{Binding KlantNaam}"/>
									</Border>

									<!-- Items -->
									<ItemsControl ItemsSource="{Binding Items}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Border Background="White"
														BorderBrush="{DynamicResource BorderSubtle}"
														BorderThickness="1"
														CornerRadius="8"
														Padding="12"
														Margin="0,0,0,10">

													<Grid ColumnDefinitions="*,220"
														  RowDefinitions="Auto,Auto">

														<!-- Linker info: zoveel mogelijk zoals je foto (plain text) -->
														<StackPanel Grid.Column="0" Spacing="2">
															<TextBlock Text="{Binding Stuks, StringFormat='{}{0} stuks in te lijsten:'}"
																	   FontWeight="Bold"
																	   Foreground="Black"/>
															<TextBlock Text="{Binding Omschrijving}" Foreground="Black"/>
															<TextBlock Text="{Binding RegelOpmerking, StringFormat='opmerking: {0}'}" FontStyle="Italic" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" IsVisible="{Binding RegelOpmerking, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

															<Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="16" Margin="0,6,0,0">
																<TextBlock Text="{Binding Breedte, StringFormat='breedte : {0} cm'}" />
																<TextBlock Grid.Column="1" Text="{Binding Hoogte, StringFormat='hoogte : {0} cm'}" />
																<TextBlock Grid.Column="2" Text="{Binding Afw, StringFormat='afw. : {0}'}" />
																<TextBlock Grid.Column="3" Text="{Binding Lijst, StringFormat='lijst : {0}'}" />
															</Grid>

															<TextBlock Text="{Binding ProductieDatum, StringFormat='productie op {0:dd/MM/yy}'}"
																	   Margin="0,6,0,0"
																	   Foreground="Black"/>
															<TextBlock Text="{Binding BonNr, StringFormat='bonnr. {0}'}"
																	   Foreground="Black"/>
														</StackPanel>

														<!-- Rechter kolom: inleg/artikel -->
														<StackPanel Grid.Column="1" Spacing="4">
															<TextBlock Text="{Binding Inleg1, StringFormat='inleg 1 : {0}'}" Foreground="Black"/>
															<TextBlock Text="{Binding Inleg2, StringFormat='inleg 2 : {0}'}" Foreground="Black"/>
															<TextBlock Text="Afwerkingen:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0"/>
															<TextBlock Text="{Binding GlasBeschrijving, StringFormat='Glas: {0}'}" Foreground="Black" IsVisible="{Binding GlasBeschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
															<TextBlock Text="{Binding Passe1Beschrijving, StringFormat='PP1: {0}'}" Foreground="Black" IsVisible="{Binding Passe1Beschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
															<TextBlock Text="{Binding Passe2Beschrijving, StringFormat='PP2: {0}'}" Foreground="Black" IsVisible="{Binding Passe2Beschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
															<TextBlock Text="{Binding DieptyeBeschrijving, StringFormat='Diepte: {0}'}" Foreground="Black" IsVisible="{Binding DieptyeBeschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
															<TextBlock Text="{Binding OpklevenBeschrijving, StringFormat='Opkleven: {0}'}" Foreground="Black" IsVisible="{Binding OpklevenBeschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
															<TextBlock Text="{Binding RugBeschrijving, StringFormat='Rug: {0}'}" Foreground="Black" IsVisible="{Binding RugBeschrijving, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
														</StackPanel>

														<Grid Grid.Row="1"
															  Grid.ColumnSpan="2"
															  ColumnDefinitions="300,*"
															  ColumnSpacing="12"
															  Margin="0,12,0,0">
															<Border Grid.Column="0"
																	Background="{DynamicResource SurfaceMutedAlt}"
																	BorderBrush="{DynamicResource BorderSubtle}"
																	BorderThickness="1"
																	CornerRadius="6"
																	Padding="10">
																<StackPanel Spacing="6">
																	<TextBlock Text="Bestellen"
																			   FontWeight="Bold"
																			   Foreground="Black"/>
																	<Border IsVisible="{Binding IsBesteld}" Background="{DynamicResource Success}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="0,0,0,2">
																		<TextBlock Text="✓ Reeds besteld" Classes="caption" Foreground="{DynamicResource TextOnDark}" FontWeight="SemiBold"/>
																	</Border>
																	<TextBlock Text="{Binding VoorraadStatusText}"
																			   Foreground="Black"
																			   FontWeight="SemiBold"/>
																	<TextBlock Text="{Binding BestelDatum, StringFormat='Besteld op: {0:dd/MM/yyyy}'}"
																			   Foreground="Black"
																			   IsVisible="{Binding IsBesteld}"/>
																	<TextBlock Text="{Binding BestellingNummer, StringFormat='Bestelnummer: {0}'}"
																			   Foreground="Black"
																			   IsVisible="{Binding HasOrder}"/>
																	<TextBlock Text="{Binding LeverancierNaam, StringFormat='Leverancier: {0}'}"
																			   Foreground="Black"
																			   IsVisible="{Binding HasOrder}"/>
																	<TextBlock Text="{Binding VerwachteLeverdatum, StringFormat='Verwacht: {0:dd/MM/yyyy}'}"
																			   Foreground="Black"
																			   IsVisible="{Binding HasOrder}"/>
																	<StackPanel Spacing="4" IsVisible="{Binding CanPlaceOrder}">
																		<WrapPanel ItemSpacing="12" LineSpacing="4">
																			<TextBlock Text="Bestelwijze:" VerticalAlignment="Center" Classes="caption"/>
																			<RadioButton GroupName="{Binding TaakId, StringFormat='BVW{0}'}"
																						 IsChecked="{Binding BestelVormIsVerstek, Mode=TwoWay}">
																				<TextBlock Text="In verstek" Classes="label"/>
																			</RadioButton>
																			<RadioButton GroupName="{Binding TaakId, StringFormat='BVW{0}'}"
																						 IsChecked="{Binding BestelVormIsInLengte, Mode=TwoWay}">
																				<TextBlock Text="In lengte" Classes="label"/>
																			</RadioButton>
																			<RadioButton GroupName="{Binding TaakId, StringFormat='BVW{0}'}"
																						 IsChecked="{Binding BestelVormIsGemonteerd, Mode=TwoWay}">
																				<TextBlock Text="Gemonteerd" Classes="label"/>
																			</RadioButton>
																		</WrapPanel>
																		<TextBlock Text="{Binding BestelEenheid, StringFormat='Eenheid: {0}'}" Classes="caption" Margin="0,2,0,0"/>
																		<Button Content="Maak bestelling"
																				Classes="AccentBtn"
																				Command="{Binding $parent[Window].((vm:WeekWerkLijstViewModel)DataContext).MarkeerBesteldCommand}"
																				CommandParameter="{Binding}"/>
																	</StackPanel>
																	<TextBlock Text="{Binding BestelDatum, StringFormat='Besteld op: {0:dd/MM/yyyy}'}"
																				   VerticalAlignment="Center"
																				   Classes="body"
																				   Foreground="{DynamicResource Success}"
																				   FontWeight="SemiBold"
																				   IsVisible="{Binding IsBesteld}"/>
																</StackPanel>
															</Border>

															<Border Grid.Column="1"
																	Background="{DynamicResource SurfaceMutedAlt}"
																	BorderBrush="{DynamicResource BorderSubtle}"
																	BorderThickness="1"
																	CornerRadius="6"
																	Padding="10">
																<StackPanel Spacing="6">
																	<TextBlock Text="Notitie (blijft bewaard)"
																			   FontWeight="Bold"
																			   Foreground="Black"/>
																	<TextBox Text="{Binding Notitie, Mode=TwoWay}"
																			 AcceptsReturn="True"
																			 TextWrapping="Wrap"
																			 MinHeight="70"
																			 MaxHeight="160"
																			 Padding="8"
																			 Foreground="Black"/>

																	<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
																		<Button Content="💾 Bewaar"
																				Command="{Binding $parent[Window].((vm:WeekWerkLijstViewModel)DataContext).SaveNotitieCommand}"
																				CommandParameter="{Binding}"
																				Classes="MainBtn"
																				Padding="12,6"/>
																	</StackPanel>
																</StackPanel>
															</Border>
														</Grid>

													</Grid>

												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</ScrollViewer>
		</Grid>

	</Grid>

		<!-- TOAST OVERLAY -->
		<ItemsControl ItemsSource="{Binding ToastMessages}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0" IsHitTestVisible="False">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate><StackPanel Spacing="8"/></ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Border Padding="14,10" CornerRadius="8" Background="{Binding BackgroundBrush}" BorderBrush="{DynamicResource BrandDark}" BorderThickness="1" MinWidth="220" MaxWidth="380">
						<TextBlock Text="{Binding Message}" Classes="body" Foreground="{DynamicResource TextOnDark}" FontWeight="SemiBold" TextWrapping="Wrap"/>
					</Border>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</Panel>
</Window>
