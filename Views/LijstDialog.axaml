<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="using:QuadroApp.Model.DB"
        x:Class="QuadroApp.Views.LijstDialog"
        x:DataType="m:TypeLijst"
        Width="520"
        Height="700"
        MinWidth="440"
        MinHeight="480"
        CanResize="True"
        Title="Lijst bewerken"
        Background="{DynamicResource SurfaceMuted}"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="10" BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" Margin="12" Padding="16" Background="{DynamicResource Surface}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock Text="Lijstgegevens" Classes="h1" Margin="0,0,0,8"/>

                <TextBlock Text="Artikelnummer" Classes="label"/>
                <TextBox Text="{Binding Artikelnummer}"/>

                <TextBlock Text="Levcode" Classes="label"/>
                <TextBox Text="{Binding Levcode}"/>

                <TextBlock Text="Leverancier" Classes="label"/>
                <TextBlock Text="{Binding Leverancier.Naam, TargetNullValue='Geen leverancier'}"
                           Classes="body"
                           TextTrimming="CharacterEllipsis"
                           ToolTip.Tip="{Binding Leverancier.Naam, TargetNullValue='Geen leverancier'}"/>

                <TextBlock Text="Breedte" Classes="label"/>
                <NumericUpDown Value="{Binding BreedteCm}" Minimum="0" Maximum="100" Increment="1"/>

                <TextBlock Text="Soort" Classes="label"/>
                <TextBox Text="{Binding Soort}"/>

                <TextBlock Text="Voorraad" Classes="label"/>
                <NumericUpDown Value="{Binding VoorraadMeter}" Increment="0.5"/>

                <TextBlock Text="InventarisKost" Classes="label"/>
                <NumericUpDown Value="{Binding InventarisKost}" Increment="0.1"/>

                <TextBlock Text="PrijsPerMeter" Classes="label"/>
                <NumericUpDown Value="{Binding PrijsPerMeter}" Increment="0.1"/>

                <TextBlock Text="Winstfactor (leeg = gebruik standaard)" Classes="label" TextWrapping="Wrap"/>
                <NumericUpDown Value="{Binding WinstFactor}" Increment="0.1" Minimum="0" Watermark="Standaard"/>

                <TextBlock Text="Afvalpercentage % (leeg = gebruik standaard)" Classes="label" TextWrapping="Wrap"/>
                <NumericUpDown Value="{Binding AfvalPercentage}" Increment="0.5" Minimum="0" Watermark="Standaard"/>

                <TextBlock Text="VasteKost" Classes="label"/>
                <NumericUpDown Value="{Binding VasteKost}" Increment="0.5"/>

                <TextBlock Text="WerkMinuten" Classes="label"/>
                <NumericUpDown Value="{Binding WerkMinuten}" Increment="1"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                    <Button Content="Annuleren" MinWidth="100" Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}" CornerRadius="8" Click="Annuleer_Click"/>
                    <Button Content="Opslaan" MinWidth="110" Background="{DynamicResource BrandDark}" Foreground="{DynamicResource TextOnDark}" FontWeight="Bold" CornerRadius="8" Click="Opslaan_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
