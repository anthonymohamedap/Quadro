{
  // ─────────────────────────────────────────────────────────────────────────
  // QuadroApp — connection string config
  //
  // This file is deployed next to QuadroApp.exe on each PC.
  // It is NOT committed to git (listed in .gitignore).
  //
  // CURRENT: SQLite (local file — single-PC mode)
  // THURSDAY: swap to PostgreSQL line below once the server is installed on PC 1.
  // ─────────────────────────────────────────────────────────────────────────

  "ConnectionStrings": {

    // ── SQLite (default — remove or comment out when switching to PostgreSQL) ─
    "Default": "Data Source=quadro.db"

    // ── PostgreSQL — PC 1 (the server itself uses localhost) ─────────────────
    // The real password is NOT stored here (US-33). Keep the __SECRET__ placeholder
    // and store the password once per PC via:  .\Scripts\set-db-secret.ps1
    // (macOS: Scripts/set-db-secret.sh). Alternative: env var QUADRO_DB_PASSWORD.
    // "Default": "Host=localhost;Port=5432;Database=quadrodb;Username=quadro;Password=__SECRET__"

    // ── PostgreSQL — PC 2 (replace X with PC 1's local IP, e.g. 192.168.1.50) ─
    // "Default": "Host=192.168.1.X;Port=5432;Database=quadrodb;Username=quadro;Password=__SECRET__"

  }

  // ── US-34: daily backups. Uncomment to override the defaults. Point Directory
  //    at a second disk / NAS / OneDrive folder so backups survive a disk crash.
  // ,"Backup": { "Directory": "D:\\QuadroBackups", "RetentionDays": 30 }
}
